};
BarShiftCache barShiftCache[20];  // Cache last 20 lookups
int barShiftCacheSize = 0;

//+------------------------------------------------------------------+
//| Cached iBarShift - O(1) lookup for repeated calls                |
//+------------------------------------------------------------------+
int GetBarShiftCached(string symbol, ENUM_TIMEFRAMES timeframe, datetime time)
{
    // Check cache first
    for(int i = 0; i < barShiftCacheSize; i++)
    {
        if(barShiftCache[i].time == time && barShiftCache[i].timeframe == timeframe)
            return barShiftCache[i].shift;
    }

    // Not in cache, calculate and store
    int shift = iBarShift(symbol, timeframe, time);

    // Add to cache (circular buffer)
    if(barShiftCacheSize < 20)
    {
        barShiftCache[barShiftCacheSize].time = time;
        barShiftCache[barShiftCacheSize].timeframe = timeframe;
        barShiftCache[barShiftCacheSize].shift = shift;
        barShiftCacheSize++;
    }
    else
    {
        // Cache full, replace oldest entry (FIFO)
        for(int i = 0; i < 19; i++)
            barShiftCache[i] = barShiftCache[i + 1];
        barShiftCache[19].time = time;
        barShiftCache[19].timeframe = timeframe;
        barShiftCache[19].shift = shift;
    }

    return shift;
}

