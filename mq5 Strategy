//+------------------------------------------------------------------+
//| Detect trade close and log TP/SL result                         |
//+------------------------------------------------------------------+
void CheckTradeClose()
{
    static ulong   trackedTickets[];
    static datetime trackedTimes[];

    // Build list of currently open positions on this symbol
    // Pre-allocate to avoid O(n²) ArrayResize in loop
    int posTotal = PositionsTotal();
    ulong   openTickets[];
    datetime openTimes[];
    ArrayResize(openTickets, posTotal);  // Pre-allocate max size
    ArrayResize(openTimes,   posTotal);

    int openCount = 0;
    for(int i = 0; i < posTotal; i++)
    {
        ulong tk = PositionGetTicket(i);
        if(!PositionSelectByTicket(tk)) continue;
        if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;

        openTickets[openCount] = tk;
        openTimes[openCount]   = (datetime)PositionGetInteger(POSITION_TIME);
        openCount++;
    }

    // Trim to actual size
    ArrayResize(openTickets, openCount);
    ArrayResize(openTimes,   openCount);

    // Add newly opened positions to tracking
    // Pre-calculate max possible size to avoid resize in loop
    int maxNewTracks = ArraySize(openTickets);
    int currentTrackedSize = ArraySize(trackedTickets);
    ArrayResize(trackedTickets, currentTrackedSize + maxNewTracks);
    ArrayResize(trackedTimes,   currentTrackedSize + maxNewTracks);

    int newTrackedCount = currentTrackedSize;
    for(int i = 0; i < ArraySize(openTickets); i++)
    {
        bool found = false;
        for(int j = 0; j < currentTrackedSize; j++)
            if(trackedTickets[j] == openTickets[i]) { found = true; break; }

        if(!found)
        {
            trackedTickets[newTrackedCount] = openTickets[i];
            trackedTimes[newTrackedCount]   = openTimes[i];
            newTrackedCount++;
        }
    }

    // Trim to actual size
    ArrayResize(trackedTickets, newTrackedCount);
    ArrayResize(trackedTimes,   newTrackedCount);

    // Find and log closed positions (ticket tracked but no longer open)
    for(int j = ArraySize(trackedTickets) - 1; j >= 0; j--)
    {
        bool stillOpen = false;
        for(int i = 0; i < ArraySize(openTickets); i++)
            if(openTickets[i] == trackedTickets[j]) { stillOpen = true; break; }

        if(!stillOpen)
        {
            ulong    closedTk = trackedTickets[j];
            datetime entryTm  = trackedTimes[j];

            HistorySelectByPosition(closedTk);

            string result     = "UNKNOWN";
            double closePrice = 0;
            double entryPrice = 0;
            double profit     = 0;

            // Pre-build lookup table for entry deals in single pass - O(n) instead of O(n²)
            int totalDeals = HistoryDealsTotal();
            ulong entryPositionIds[];
            double entryPrices[];
            ArrayResize(entryPositionIds, totalDeals);
            ArrayResize(entryPrices, totalDeals);

            int entryCount = 0;
            for(int k = 0; k < totalDeals; k++)
            {
                ulong t2 = HistoryDealGetTicket(k);
                if(HistoryDealGetInteger(t2, DEAL_ENTRY) == DEAL_ENTRY_IN)
                {
                    entryPositionIds[entryCount] = (ulong)HistoryDealGetInteger(t2, DEAL_POSITION_ID);
                    entryPrices[entryCount] = HistoryDealGetDouble(t2, DEAL_PRICE);
                    entryCount++;
                }
            }

            // Now search for exit deal - O(n) with cached entry lookup
            for(int i = totalDeals - 1; i >= 0; i--)
            {
                ulong dk = HistoryDealGetTicket(i);
                if(HistoryDealGetString(dk,  DEAL_SYMBOL)  != _Symbol)        continue;
                if(HistoryDealGetInteger(dk, DEAL_ENTRY)   != DEAL_ENTRY_OUT) continue;
                if((ulong)HistoryDealGetInteger(dk, DEAL_POSITION_ID) != closedTk) continue;

                closePrice = HistoryDealGetDouble(dk, DEAL_PRICE);
                profit     = HistoryDealGetDouble(dk, DEAL_PROFIT);
                ENUM_DEAL_REASON reason = (ENUM_DEAL_REASON)HistoryDealGetInteger(dk, DEAL_REASON);

                // O(n) lookup instead of nested loop
                for(int m = 0; m < entryCount; m++)
                {
                    if(entryPositionIds[m] == closedTk)
                    {
                        entryPrice = entryPrices[m];
                        break;
                    }
                }

                if(reason == DEAL_REASON_TP)      result = "TP";
                else if(reason == DEAL_REASON_SL) result = "SL";
                else result = (profit > 0) ? "TP" : "SL";
                break;
            }

            LogTradeResult(result, entryTm, entryPrice, closePrice, profit);
            ArrayRemove(trackedTickets, j, 1);
            ArrayRemove(trackedTimes,   j, 1);
        }
    }
}

