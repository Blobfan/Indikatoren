//+------------------------------------------------------------------+
//| Expert tick function                                             |
//+------------------------------------------------------------------+
void OnTick()
{
    // Detect trade close on every tick (before new-bar gate)
    CheckTradeClose();

    // Manage open trades on EVERY TICK for correct BE/Trailing SL timing
    ManageOpenTrades();

    // EMA-Break Close: Tick-basierter Preisvergleich gegen gespeicherten EMA-Wert
    CheckCloseAllTick();

    // Check if new bar
    static datetime lastBarTime = 0;
    datetime currentBarTime = iTime(_Symbol, PERIOD_CURRENT, 0);

    if(currentBarTime == lastBarTime)
    {
        // Update dashboard even if not new bar
        if(InpShowDashboard)
            UpdateDashboard();
        return;
    }

    lastBarTime = currentBarTime;

    // Update indicators
    if(!UpdateIndicators())
        return;

    // Initialize swing structure on first run
    if(!initialized && Bars(_Symbol, PERIOD_CURRENT) >= MathMin(InpWarmupBars, 34))
    {
        InitializeSwingStructure();
    }

    // Main logic — use else if so the init bar is NOT processed twice
    // (InitializeSwingStructure already calls CalculateSupertrend internally)
    else if(initialized)
    {
        CalculateSupertrend();   // FIRST: Calculate ST (needed for trend-gated BOS)
        UpdateSwingStructure();
        UpdateSupertrendCandidates();
        DrawSupertrendLines();
        DrawEMALines();
        UpdateADX();

        CheckTradeSignals();
        CheckCloseAllConditions();
        // Note: ManageOpenTrades() is already called every tick above

        // Update dashboard
        if(InpShowDashboard)
            UpdateDashboard();
    }

    // === HTF UPDATE (WICHTIG: Nach der Hauptlogik!) ===
    if(InpUseHTF && initialized)
    {
        // Retry HTF initialization each bar until enough HTF bars are available
        // (CTF initializes after 34 M15 bars, but HTF needs 34 H1 bars = ~24 h later)
        if(!htfInitialized)
            InitializeHTFSwingStructure();

        if(htfInitialized)
            UpdateHTFSwingStructure();

        DrawHTFSupertrendLines();  // Always draw (function exits early silently if no data)
    }
}

