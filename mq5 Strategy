int OnInit()
{
    // Initialize indicator handles
    emaFastHandle = iMA(_Symbol, InpEMATimeframe, InpEMAFast, 0, MODE_EMA, PRICE_CLOSE);
    emaSlowHandle = iMA(_Symbol, InpEMATimeframe, InpEMASlow, 0, MODE_EMA, PRICE_CLOSE);
    atrHandle = iATR(_Symbol, PERIOD_CURRENT, InpSTperiod);

    if(emaFastHandle == INVALID_HANDLE || emaSlowHandle == INVALID_HANDLE || atrHandle == INVALID_HANDLE)
    {
        Print("Error creating indicator handles!");
        return INIT_FAILED;
    }

    // Initialize HTF ATR handle if HTF is enabled
    if(InpUseHTF)
    {
        htfAtrHandle = iATR(_Symbol, InpHTFTimeframe, InpSTperiod);
        if(htfAtrHandle == INVALID_HANDLE)
        {
            Print("Error creating HTF ATR handle!");
            return INIT_FAILED;
        }
    }

    // ADX immer initialisieren (auch wenn Filter aus) -- Dashboard zeigt Wert immer
    ArrayResize(adxMaBuf, MathMax(InpADXSmoothing2, 1));
    ArrayInitialize(adxMaBuf, 0.0);
    ArrayResize(adxSeedBufDmPlus,  InpADXPeriod);
    ArrayResize(adxSeedBufDmMinus, InpADXPeriod);
    ArrayResize(adxSeedBufTr,      InpADXPeriod);
    ArrayInitialize(adxSeedBufDmPlus,  0.0);
    ArrayInitialize(adxSeedBufDmMinus, 0.0);
    ArrayInitialize(adxSeedBufTr,      0.0);
    adxSeedCount   = 0;
    adxRmaSeeded   = false;
    adxMaBufIdx    = 0;
    adxInitialized = false;
    adxRmaSmDmPlus = adxRmaSmDmMinus = adxRmaSmTr = adxRmaAdx = 0.0;
    adxPrevHigh = adxPrevLow = adxPrevClose = 0.0;
    adxLastBar  = 0;
    PreloadADX();

    // Set array as series
    ArraySetAsSeries(upBuffer, true);
    ArraySetAsSeries(dnBuffer, true);
    ArraySetAsSeries(htfUpBuffer, true);
    ArraySetAsSeries(htfDnBuffer, true);

    // Initialize variables
    initialized = false;
    tradeActive = false;

    // Initialize CSV Logging
    {
        string ts = TimeToString(TimeCurrent(), TIME_DATE);
        StringReplace(ts, ".", "-");
        logFileName = _Symbol + "_NEW_P" + IntegerToString(PERIOD_CURRENT) + "_" + ts + ".csv";
        FolderCreate("DTFX_Logs", FILE_COMMON);
        int fh = FileOpen("DTFX_Logs\\" + logFileName, FILE_WRITE | FILE_TXT | FILE_ANSI | FILE_COMMON);
        if(fh != INVALID_HANDLE)
        {
            FileWriteString(fh, "DateTime,Strategy,TradeType,Session,EntryPrice,StopLoss,TakeProfit,ValidSH,ValidSL,ATR,AllowDir,EMAAllow,SwingIntact,RangeWide,HTFAlign,ADX\r\n");
            FileClose(fh);
            Print("CSV Log: C:\\Users\\arthu\\AppData\\Roaming\\MetaQuotes\\Terminal\\Common\\Files\\DTFX_Logs\\", logFileName);
        }
        else
            Print("CSV Log ERROR: konnte Datei nicht erstellen (Error ", GetLastError(), ")");
    }

    // Create dashboard
    if(InpShowDashboard)
        CreateDashboard();

    // Initialize blocked hours cache for O(1) lookup
    ArrayInitialize(blockedHours, false);
    if(InpBlockHour1 >= 0 && InpBlockHour1 < 24) blockedHours[InpBlockHour1] = true;
    if(InpBlockHour2 >= 0 && InpBlockHour2 < 24) blockedHours[InpBlockHour2] = true;
    if(InpBlockHour3 >= 0 && InpBlockHour3 < 24) blockedHours[InpBlockHour3] = true;
    if(InpBlockHour4 >= 0 && InpBlockHour4 < 24) blockedHours[InpBlockHour4] = true;
    if(InpBlockHour5 >= 0 && InpBlockHour5 < 24) blockedHours[InpBlockHour5] = true;

    Print("DTFX Strategy EA initialized successfully");
    return INIT_SUCCEEDED;
}

