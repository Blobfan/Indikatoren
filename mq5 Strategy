//+------------------------------------------------------------------+
//| Initialize HTF Swing Structure                                   |
//+------------------------------------------------------------------+
void InitializeHTFSwingStructure()
{
    if(!InpUseHTF) return;

    // Mindestens 2 HTF-Bars: Schnell-Init per Preisposition möglich; voller Warmup ab InpSTperiod+4
    int htfBars = iBars(_Symbol, InpHTFTimeframe);
    if(htfBars < 2)
        return;

    // Vollständiger Supertrend-Warmup – kalibriert htfTrend, Buffers, Swings & BOS korrekt
    WarmupHTFSupertrend();

    if(!htfInitialized)
    {
        Print("HTF Init: WarmupHTFSupertrend fehlgeschlagen");
        return;
    }

    // Initiale HTF Swing Labels zeichnen (nur ohne Warmup – mit Warmup werden Labels im Loop gezeichnet)
    if(InpShowSwingLabels && htfValidSH > 0 && InpWarmupBars <= 0)
    {
        int labelWindow = MathMin(htfBars - 1, 34);
        if(labelWindow >= 1)
        {
            int htfHighestBar = iHighest(_Symbol, InpHTFTimeframe, MODE_HIGH, labelWindow, 1);
            int htfLowestBar  = iLowest (_Symbol, InpHTFTimeframe, MODE_LOW,  labelWindow, 1);
            DrawHTFSwingLabel("HTF_SH_init", htfHighestBar, htfValidSH, "HTF H", true);
            DrawHTFSwingLabel("HTF_SL_init", htfLowestBar,  htfValidSL, "HTF L", false);
        }
    }

    Print("HTF initialisiert: Trend=", htfTrend == 1 ? "UP" : "DOWN",
          " BOS=", htfLastBOS, " SH=", htfValidSH, " SL=", htfValidSL,
          " TF=", EnumToString(InpHTFTimeframe));
}

//+------------------------------------------------------------------+
//| Calculate HTF Supertrend                                         |
//+------------------------------------------------------------------+
void CalculateHTFSupertrend()
{
    if(!InpUseHTF || htfAtrHandle == INVALID_HANDLE) return;

    double htfAtr[];
    ArraySetAsSeries(htfAtr, true);

    if(CopyBuffer(htfAtrHandle, 0, 0, 3, htfAtr) < 3)
        return;

    double htfHigh1 = iHigh(_Symbol, InpHTFTimeframe, 1);
    double htfLow1 = iLow(_Symbol, InpHTFTimeframe, 1);
    double htfClose1 = iClose(_Symbol, InpHTFTimeframe, 1);
    double htfClose2 = iClose(_Symbol, InpHTFTimeframe, 2);

    double htfSrc = (htfHigh1 + htfLow1) / 2.0;
    double htfUp = htfSrc - (InpSTmultiplier * htfAtr[1]);
    double htfDn = htfSrc + (InpSTmultiplier * htfAtr[1]);

    double htfPrevUp = 0;
    double htfPrevDn = 0;

    if(ArraySize(htfUpBuffer) > 0)
    {
        htfPrevUp = htfUpBuffer[0];
        htfPrevDn = htfDnBuffer[0];
    }
    else
    {
        htfPrevUp = htfUp;
        htfPrevDn = htfDn;
    }

    // ECHTE SUPERTREND LOGIK (wie beim CTF)
    if(htfClose2 > htfPrevUp)
        htfUp = MathMax(htfUp, htfPrevUp);
    if(htfClose2 < htfPrevDn)
        htfDn = MathMin(htfDn, htfPrevDn);

    // Buffer aktualisieren
    ArrayResize(htfUpBuffer, ArraySize(htfUpBuffer) + 1);
    ArrayResize(htfDnBuffer, ArraySize(htfDnBuffer) + 1);

    for(int i = ArraySize(htfUpBuffer) - 1; i > 0; i--)
    {
        htfUpBuffer[i] = htfUpBuffer[i - 1];
        htfDnBuffer[i] = htfDnBuffer[i - 1];
    }

    htfUpBuffer[0] = htfUp;
    htfDnBuffer[0] = htfDn;

    // Cap HTF buffer size to prevent unbounded memory growth
    if(ArraySize(htfUpBuffer) > 4)
    {
        ArrayResize(htfUpBuffer, 4);
        ArrayResize(htfDnBuffer, 4);
    }

    // === STEP 1: HTF EXTREMPUNKTE TRACKING MIT ALTEM TREND (VOR Trend-Bestimmung!) ===
    if(htfTrend == 1)
    {
        if(htfHigh1 > htfCurrentUptrendHigh || htfCurrentUptrendHigh == 0)
        {
            htfCurrentUptrendHigh = htfHigh1;
            htfCurrentUptrendHighTime = iTime(_Symbol, InpHTFTimeframe, 1);
        }
    }
    if(htfTrend == -1)
    {
        if(htfLow1 < htfCurrentDowntrendLow || htfCurrentDowntrendLow == 0)
        {
            htfCurrentDowntrendLow = htfLow1;
            htfCurrentDowntrendLowTime = iTime(_Symbol, InpHTFTimeframe, 1);
        }
    }

    // === STEP 2: HTF TREND BESTIMMEN ===
    htfPrevTrend = htfTrend;
    if(htfTrend == -1 && htfClose1 > htfPrevDn)
        htfTrend = 1;
    else if(htfTrend == 1 && htfClose1 < htfPrevUp)
        htfTrend = -1;

    // === STEP 3: BEI TRENDWECHSEL: SPEICHERE EXTREMPUNKTE & INITIALISIERE NEUES TRACKING ===
    bool htfTrendChanged = (htfTrend != htfPrevTrend && htfPrevTrend != 0);

    if(htfTrendChanged)
    {
        if(htfTrend == -1)  // Wechsel zu DOWNTREND
        {
            htfLastUptrendHigh = htfCurrentUptrendHigh;
            htfLastUptrendHighTime = htfCurrentUptrendHighTime;

            Print("HTF ST Wechsel zu DOWN: HIGH = ", htfLastUptrendHigh, " bei Zeit ", TimeToString(htfLastUptrendHighTime));

            // Initialisiere neues Downtrend-Tracking mit aktuellem Bar
            htfCurrentDowntrendLow = htfLow1;
            htfCurrentDowntrendLowTime = iTime(_Symbol, InpHTFTimeframe, 1);
        }
        else if(htfTrend == 1)  // Wechsel zu UPTREND
        {
            htfLastDowntrendLow = htfCurrentDowntrendLow;
            htfLastDowntrendLowTime = htfCurrentDowntrendLowTime;

            Print("HTF ST Wechsel zu UP: LOW = ", htfLastDowntrendLow, " bei Zeit ", TimeToString(htfLastDowntrendLowTime));

            // Initialisiere neues Uptrend-Tracking mit aktuellem Bar
            htfCurrentUptrendHigh = htfHigh1;
            htfCurrentUptrendHighTime = iTime(_Symbol, InpHTFTimeframe, 1);
        }
    }
}

//+------------------------------------------------------------------+
//| Draw HTF Supertrend Lines on Chart                               |
//+------------------------------------------------------------------+
void DrawHTFSupertrendLines()
{
    if(!InpShowHTFSupertrendLines || !InpUseHTF) return;
    if(!htfInitialized || htfAtrHandle == INVALID_HANDLE) return;

    int htfBars = iBars(_Symbol, InpHTFTimeframe);
    if(htfBars < 4) return;
    int maxBars = MathMin(htfBars, 200);  // Weniger Bars für HTF

    // Delete old HTF supertrend objects
    for(int i = ObjectsTotal(0) - 1; i >= 0; i--)
    {
        string objName = ObjectName(0, i);
        if(StringFind(objName, htfStLinePrefix) >= 0)
            ObjectDelete(0, objName);
    }

    // ATR und Preisdaten für HTF
    double htfAtr[];
    double htfHigh_arr[], htfLow_arr[], htfClose_arr[];
    ArraySetAsSeries(htfAtr, true);
    ArraySetAsSeries(htfHigh_arr, true);
    ArraySetAsSeries(htfLow_arr, true);
    ArraySetAsSeries(htfClose_arr, true);

    if(CopyBuffer(htfAtrHandle, 0, 0, maxBars, htfAtr) <= 0) return;
    if(CopyHigh(_Symbol, InpHTFTimeframe, 0, maxBars, htfHigh_arr) <= 0) return;
    if(CopyLow(_Symbol, InpHTFTimeframe, 0, maxBars, htfLow_arr) <= 0) return;
    if(CopyClose(_Symbol, InpHTFTimeframe, 0, maxBars, htfClose_arr) <= 0) return;

    // Tatsächlich kopierte Bars verwenden
    maxBars = MathMin(ArraySize(htfAtr), maxBars);

    double htfUp_arr[], htfDn_arr[];
    ArrayResize(htfUp_arr, maxBars);
    ArrayResize(htfDn_arr, maxBars);
    int htfTrend_arr[];
    ArrayResize(htfTrend_arr, maxBars);

    // Calculate HTF Supertrend values
    for(int i = maxBars - 1; i >= 0; i--)
    {
        double htfSrc = (htfHigh_arr[i] + htfLow_arr[i]) / 2.0;
        double htfUp = htfSrc - (InpSTmultiplier * htfAtr[i]);
        double htfDn = htfSrc + (InpSTmultiplier * htfAtr[i]);

        if(i < maxBars - 1)
        {
            double htfPrevUp = htfUp_arr[i + 1];
            double htfPrevDn = htfDn_arr[i + 1];
            double htfPrevClose = htfClose_arr[i + 1];

            if(htfPrevClose > htfPrevUp)
                htfUp = MathMax(htfUp, htfPrevUp);

            if(htfPrevClose < htfPrevDn)
                htfDn = MathMin(htfDn, htfPrevDn);

            int localHtfPrevTrend = htfTrend_arr[i + 1];
            int htfCurrentTrend = localHtfPrevTrend;

            if(localHtfPrevTrend == -1 && htfClose_arr[i] > htfPrevDn)
                htfCurrentTrend = 1;
            else if(localHtfPrevTrend == 1 && htfClose_arr[i] < htfPrevUp)
                htfCurrentTrend = -1;

            htfTrend_arr[i] = htfCurrentTrend;
        }
        else
        {
            htfTrend_arr[i] = 1;
        }

        htfUp_arr[i] = htfUp;
        htfDn_arr[i] = htfDn;
    }

    // Draw HTF Supertrend as trend line segments
    // Blue when below price (uptrend), Magenta when above price (downtrend)
    for(int i = maxBars - 2; i >= 0; i--)
    {
        datetime time1 = iTime(_Symbol, InpHTFTimeframe, i + 1);
        datetime time2 = iTime(_Symbol, InpHTFTimeframe, i);

        double price1, price2;
        color lineColor;

        if(htfTrend_arr[i + 1] == 1) // HTF Uptrend - blue line below price
        {
            price1 = htfUp_arr[i + 1];
            price2 = htfUp_arr[i];
            lineColor = InpHTFSupertrendUpColor;
        }
        else // HTF Downtrend - magenta line above price
        {
            price1 = htfDn_arr[i + 1];
            price2 = htfDn_arr[i];
            lineColor = InpHTFSupertrendDownColor;
        }

        // Check if trend changed
        if(i < maxBars - 2 && htfTrend_arr[i] != htfTrend_arr[i + 1])
        {
            // Trend changed - draw to current point
            string objName = htfStLinePrefix + IntegerToString(i) + "_change";
            if(ObjectCreate(0, objName, OBJ_TREND, 0, time1, price1, time2, price2))
            {
                ObjectSetInteger(0, objName, OBJPROP_COLOR, lineColor);
                ObjectSetInteger(0, objName, OBJPROP_WIDTH, InpHTFSupertrendWidth);
                ObjectSetInteger(0, objName, OBJPROP_RAY_RIGHT, false);
                ObjectSetInteger(0, objName, OBJPROP_BACK, true);  // HTF im Hintergrund
            }
        }
        else if(htfTrend_arr[i] == htfTrend_arr[i + 1])
        {
            // Same trend - continue line
            string objName = htfStLinePrefix + IntegerToString(i);
            if(ObjectCreate(0, objName, OBJ_TREND, 0, time1, price1, time2, price2))
            {
                ObjectSetInteger(0, objName, OBJPROP_COLOR, lineColor);
                ObjectSetInteger(0, objName, OBJPROP_WIDTH, InpHTFSupertrendWidth);
                ObjectSetInteger(0, objName, OBJPROP_RAY_RIGHT, false);
                ObjectSetInteger(0, objName, OBJPROP_BACK, true);  // HTF im Hintergrund
            }
        }
    }

    ChartRedraw();
}

//+------------------------------------------------------------------+
//| Close All Positions bei konfigurierbaren Bedingungen             |
//+------------------------------------------------------------------+
// Berechnet den Slow-EMA-Wert pro Bar und speichert ihn in g_emaSlowForClose.
// Der eigentliche Preisvergleich erfolgt tick-basiert in CheckCloseAllTick().
void CheckCloseAllConditions()
{
    if(InpCloseMode != CLOSE_EMA_BREAK) return;

    // Slow EMA manuell berechnen – kein Handle / BarsCalculated-Problem (wie DrawEMALines)
    int totalBars = iBars(_Symbol, InpEMATimeframe);
    if(totalBars < 2) return;
    int warmup = MathMax(InpEMASlow * 3, 50);
    int copyN  = MathMin(warmup + 2, totalBars);

    double cl[];
    ArraySetAsSeries(cl, true);
    if(CopyClose(_Symbol, InpEMATimeframe, 0, copyN, cl) < copyN) return;

    double alpha = 2.0 / (InpEMASlow + 1);
    double ema = cl[copyN - 1];           // Seed = älteste Bar
    for(int i = copyN - 2; i >= 1; i--)  // Stopp bei Index 1 = letzte geschlossene HTF-Bar
        ema = ema + alpha * (cl[i] - ema);

    g_emaSlowForClose = ema;  // Wert speichern für Tick-Vergleich
}

// Tick-basierter EMA-Break Check: vergleicht aktuellen Preis gegen g_emaSlowForClose.
// Läuft jeden Tick → reagiert sofort wenn Preis unter EMA fällt, nicht erst bei neuer Bar.
void CheckCloseAllTick()
{
    if(InpCloseMode != CLOSE_EMA_BREAK) return;
    if(g_emaSlowForClose <= 0.0) return;
    if(!PositionSelect(_Symbol)) return;
    if(PositionGetInteger(POSITION_TYPE) != POSITION_TYPE_BUY) return;

    double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
    if(currentPrice < g_emaSlowForClose)
    {
        trade.PositionClose(_Symbol);
        Print("[CLOSE EMA BREAK] Preis (", currentPrice, ") unter Slow EMA (", g_emaSlowForClose, ") → Long geschlossen");
    }
}

//+------------------------------------------------------------------+
//| Update HTF Swing Structure                                       |
//+------------------------------------------------------------------+
void UpdateHTFSwingStructure()
{
    if(!InpUseHTF || !htfInitialized) return;

    // Prüfe ob neue HTF Bar
    datetime currentHTFBarTime = iTime(_Symbol, InpHTFTimeframe, 0);
    if(currentHTFBarTime == lastHTFBarTime)
        return;

    lastHTFBarTime = currentHTFBarTime;

    // HTF Supertrend berechnen
    CalculateHTFSupertrend();

    bool htfBuySignal = (htfTrend == 1 && htfPrevTrend == -1);
    bool htfSellSignal = (htfTrend == -1 && htfPrevTrend == 1);

    // === CLOSE ALL: Long schließen wenn HTF in Downtrend dreht ===
    if(htfSellSignal && InpCloseMode == CLOSE_HTF_FLIP)
    {
        if(PositionSelect(_Symbol) && PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY)
        {
            trade.PositionClose(_Symbol);
            Print("[CLOSE HTF FLIP] HTF dreht DOWNTREND → Long Position geschlossen");
        }
    }

    // === HTF SWING HIGH BEI WECHSEL ZU DOWNTREND ===
    if(htfSellSignal && htfLastUptrendHigh > 0)
    {
        htfValidSH = htfLastUptrendHigh;

        int htfBarIndex = GetBarShiftCached(_Symbol, InpHTFTimeframe, htfLastUptrendHighTime);

        if(InpShowSwingLabels)
        {
            DrawHTFSwingLabel("HTF_SH_" + IntegerToString(TimeCurrent()),
                            htfBarIndex,
                            htfLastUptrendHigh,
                            "HTF H",
                            true);
        }

        Print("HTF H Label gesetzt bei Bar ", htfBarIndex, " (Zeit: ", TimeToString(htfLastUptrendHighTime), ") auf Preis ", htfLastUptrendHigh);
    }

    // === HTF SWING LOW BEI WECHSEL ZU UPTREND ===
    if(htfBuySignal && htfLastDowntrendLow > 0)
    {
        htfValidSL = htfLastDowntrendLow;

        int htfBarIndex = GetBarShiftCached(_Symbol, InpHTFTimeframe, htfLastDowntrendLowTime);

        if(InpShowSwingLabels)
        {
            DrawHTFSwingLabel("HTF_SL_" + IntegerToString(TimeCurrent()),
                            htfBarIndex,
                            htfLastDowntrendLow,
                            "HTF L",
                            false);
        }

        Print("HTF L Label gesetzt bei Bar ", htfBarIndex, " (Zeit: ", TimeToString(htfLastDowntrendLowTime), ") auf Preis ", htfLastDowntrendLow);
    }

    // === HTF BOS DETECTION ===
    double htfCurrentHigh = iHigh(_Symbol, InpHTFTimeframe, 1);
    double htfCurrentLow = iLow(_Symbol, InpHTFTimeframe, 1);
    double htfCurrentClose = iClose(_Symbol, InpHTFTimeframe, 1);
    double htfCurrentOpen = iOpen(_Symbol, InpHTFTimeframe, 1);

    double htfBodyHigh = MathMax(htfCurrentClose, htfCurrentOpen);
    double htfBodyLow = MathMin(htfCurrentClose, htfCurrentOpen);

    // HTF BOS UP: Preis bricht über vorheriges HTF Swing High
    if(htfValidSH > 0 && htfBodyHigh > htfValidSH)
    {
        htfLastBOS = "UP";
        Print("HTF BOS UP: Preis ", htfBodyHigh, " > HTF SH ", htfValidSH);
    }

    // HTF BOS DOWN: Preis bricht unter vorheriges HTF Swing Low
    if(htfValidSL > 0 && htfBodyLow < htfValidSL)
    {
        htfLastBOS = "DOWN";
        Print("HTF BOS DOWN: Preis ", htfBodyLow, " < HTF SL ", htfValidSL);
    }
}

//+------------------------------------------------------------------+
//| Draw HTF Swing Label (in Blue)                                   |
//+------------------------------------------------------------------+
void DrawHTFSwingLabel(string name, int shift, double price, string text, bool isHigh)
{
    // WICHTIG: shift ist auf HTF-Timeframe, aber wir wollen auf CTF zeichnen!
    // Finde die EXAKTE CTF-Kerze, die das Extrem gebildet hat

    datetime htfBarTime = iTime(_Symbol, InpHTFTimeframe, shift);
    datetime htfBarEndTime = htfBarTime + PeriodSeconds(InpHTFTimeframe);

    // Finde alle CTF-Kerzen innerhalb dieser HTF-Kerze
    int ctfStartBar = GetBarShiftCached(_Symbol, PERIOD_CURRENT, htfBarEndTime);
    int ctfEndBar = GetBarShiftCached(_Symbol, PERIOD_CURRENT, htfBarTime);

    // Suche die CTF-Kerze mit dem Extrem
    int extremeBar = ctfEndBar;
    double extremeValue = isHigh ? 0 : DBL_MAX;

    for(int i = ctfStartBar; i <= ctfEndBar; i++)
    {
        if(isHigh)
        {
            double high = iHigh(_Symbol, PERIOD_CURRENT, i);
            if(high > extremeValue)
            {
                extremeValue = high;
                extremeBar = i;
            }
        }
        else
        {
            double low = iLow(_Symbol, PERIOD_CURRENT, i);
            if(low < extremeValue)
            {
                extremeValue = low;
                extremeBar = i;
            }
        }
    }

    // Verwende die EXAKTE CTF-Zeit für das Label
    datetime time = iTime(_Symbol, PERIOD_CURRENT, extremeBar);

    if(ObjectFind(0, name) >= 0)
        ObjectDelete(0, name);

    // Berechne Offset basierend auf ATR für bessere Sichtbarkeit
    double atr[];
    ArraySetAsSeries(atr, true);
    double offsetDistance = 0;

    if(CopyBuffer(atrHandle, 0, extremeBar, 1, atr) > 0)
        offsetDistance = atr[0] * 0.8;  // Größeren Offset für HTF Labels
    else
        offsetDistance = (iHigh(_Symbol, PERIOD_CURRENT, extremeBar) - iLow(_Symbol, PERIOD_CURRENT, extremeBar)) * 3;

    // Preis mit Offset
    double adjustedPrice = isHigh ? (price + offsetDistance) : (price - offsetDistance);

    // HTF Labels in BLAU (größere Dreiecke)
    color triangleColor = InpHTFSwingColor;

    // GRÖßERE Dreiecke für HTF
    double triangleSize = offsetDistance * 0.5;  // Größer als CTF
    long htfPeriodSeconds = PeriodSeconds(InpHTFTimeframe);
    datetime timeOffset = (datetime)(htfPeriodSeconds * 0.5);

    // Dreieck-Koordinaten
    datetime time1, time2, time3;
    double price1, price2, price3;

    if(isHigh)
    {
        // Dreieck zeigt nach OBEN (für High)
        time1 = time - timeOffset;
        price1 = adjustedPrice + triangleSize;

        time2 = time + timeOffset;
        price2 = adjustedPrice + triangleSize;

        time3 = time;
        price3 = adjustedPrice;
    }
    else
    {
        // Dreieck zeigt nach UNTEN (für Low)
        time1 = time - timeOffset;
        price1 = adjustedPrice - triangleSize;

        time2 = time + timeOffset;
        price2 = adjustedPrice - triangleSize;

        time3 = time;
        price3 = adjustedPrice;
    }

    if(ObjectCreate(0, name, OBJ_TRIANGLE, 0, time1, price1, time2, price2, time3, price3))
    {
        ObjectSetInteger(0, name, OBJPROP_COLOR, triangleColor);
        ObjectSetInteger(0, name, OBJPROP_FILL, true);
        ObjectSetInteger(0, name, OBJPROP_BACK, false);
        ObjectSetInteger(0, name, OBJPROP_WIDTH, 3);  // Dicker als CTF
    }
}

//+------------------------------------------------------------------+
//| Check HTF and CTF Alignment                                      |
//+------------------------------------------------------------------+
bool IsHTFAligned(string direction)
{
    if(!InpUseHTF) return true;  // Wenn HTF nicht aktiv, immer erlaubt

    // Prüfe HTF-Richtung (unabhängig von RequireAlignment - für Dashboard etc.)
    if(direction == "UP")
        return (htfLastBOS == "UP");
    else if(direction == "DOWN")
        return (htfLastBOS == "DOWN");

    return false;
}

//+------------------------------------------------------------------+
//| Get current trading session name (UTC)                          |
//+------------------------------------------------------------------+
string GetSession()
{
    MqlDateTime gmt;
    TimeToStruct(TimeGMT(), gmt);
    int h = gmt.hour;
    if(h >= 13 && h < 16) return "Overlap";
    if(h >=  7 && h < 13) return "London";
    if(h >= 16 && h < 21) return "NY";
    if(h >= 21 || h <  6) return "Asia";
    return "Off";
}

