//+------------------------------------------------------------------+
//| Update Dashboard                                                  |
//+------------------------------------------------------------------+
void UpdateDashboard()
{
    // Update Trend
    string trendText = lastBOS == "UP" ? "UPTREND" : (lastBOS == "DOWN" ? "DOWNTREND" : "NONE");
    color trendColor = lastBOS == "UP" ? clrLime : (lastBOS == "DOWN" ? clrRed : clrGray);
    ObjectSetString(0, dashboardName + "_Trend", OBJPROP_TEXT, "CTF Trend: " + trendText);
    ObjectSetInteger(0, dashboardName + "_Trend", OBJPROP_COLOR, trendColor);

    // Update HTF Trend
    string htfTrendText = htfLastBOS == "UP" ? "UPTREND" : (htfLastBOS == "DOWN" ? "DOWNTREND" : "NONE");
    color htfTrendColor = htfLastBOS == "UP" ? clrLime : (htfLastBOS == "DOWN" ? clrRed : clrGray);
    ObjectSetString(0, dashboardName + "_HTFTrend", OBJPROP_TEXT, "HTF Trend: " + htfTrendText);
    ObjectSetInteger(0, dashboardName + "_HTFTrend", OBJPROP_COLOR, htfTrendColor);

    // Update ST Trend
    string stText = trend == 1 ? "UPTREND" : "DOWNTREND";
    color stColor = trend == 1 ? clrLime : clrRed;
    ObjectSetString(0, dashboardName + "_STTrend", OBJPROP_TEXT, "ST Trend: " + stText);
    ObjectSetInteger(0, dashboardName + "_STTrend", OBJPROP_COLOR, stColor);

    // Update Swing High
    ObjectSetString(0, dashboardName + "_SwingHigh", OBJPROP_TEXT, "CTF High: " + DoubleToString(validSH, _Digits));

    // Update Swing Low
    ObjectSetString(0, dashboardName + "_SwingLow", OBJPROP_TEXT, "CTF Low: " + DoubleToString(validSL, _Digits));

    // Update HTF Swing High
    ObjectSetString(0, dashboardName + "_HTFSwingHigh", OBJPROP_TEXT, "HTF High: " + DoubleToString(htfValidSH, _Digits));

    // Update HTF Swing Low
    ObjectSetString(0, dashboardName + "_HTFSwingLow", OBJPROP_TEXT, "HTF Low: " + DoubleToString(htfValidSL, _Digits));

    // Update HTF Alignment Status
    bool htfAlignedUp = IsHTFAligned("UP");
    bool htfAlignedDown = IsHTFAligned("DOWN");
    string htfAlignText = "NO";
    color htfAlignColor = clrRed;

    if(InpUseHTF && InpRequireHTFAlignment)
    {
        if(lastBOS == "UP" && htfAlignedUp)
        {
            htfAlignText = "YES (UP)";
            htfAlignColor = clrLime;
        }
        else if(lastBOS == "DOWN" && htfAlignedDown)
        {
            htfAlignText = "YES (DOWN)";
            htfAlignColor = clrLime;
        }
        else
        {
            htfAlignText = "NO (CTF:" + lastBOS + " HTF:" + htfLastBOS + ")";
            htfAlignColor = clrRed;
        }
    }
    else if(InpUseHTF && !InpRequireHTFAlignment)
    {
        htfAlignText = "OPTIONAL";
        htfAlignColor = clrYellow;
    }
    else
    {
        htfAlignText = "DISABLED";
        htfAlignColor = clrGray;
    }

    ObjectSetString(0, dashboardName + "_HTFAlignment", OBJPROP_TEXT, "HTF Aligned: " + htfAlignText);
    ObjectSetInteger(0, dashboardName + "_HTFAlignment", OBJPROP_COLOR, htfAlignColor);

    // Update Position
    string posText = "NONE";
    color posColor = clrGray;
    if(PositionSelect(_Symbol))
    {
        ENUM_POSITION_TYPE posType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
        if(posType == POSITION_TYPE_BUY)
        {
            posText = "LONG";
            posColor = clrLime;
        }
        else
        {
            posText = "SHORT";
            posColor = clrRed;
        }
    }
    ObjectSetString(0, dashboardName + "_Position", OBJPROP_TEXT, "Position: " + posText);
    ObjectSetInteger(0, dashboardName + "_Position", OBJPROP_COLOR, posColor);

    // Update EMA Condition
    string emaConditionText = "OFF";
    if(InpUseEMAFilter)
    {
        emaConditionText = (priceWasBelowSlowEMA && priceWasAboveSlowEMA) ? "BOTH" :
                           (priceWasBelowSlowEMA) ? "BELOW ✓" :
                           (priceWasAboveSlowEMA) ? "ABOVE ✓" : "WAITING";
    }
    ObjectSetString(0, dashboardName + "_EMACondition", OBJPROP_TEXT, "EMA Touch: " + emaConditionText);

    // === LOCAL LEG FILTER STATUS ===
    double atrDash[];
    ArraySetAsSeries(atrDash, true);
    double atrNowDash = 0;
    if(CopyBuffer(atrHandle, 0, 0, 1, atrDash) > 0) atrNowDash = atrDash[0];

    bool inPos = PositionSelect(_Symbol);

    string legText;
    color  legColor;
    string legStatusText;
    color  legStatusColor;

    if(inPos && dashEntryDir != "-")
    {
        // --- IN POSITION: Zeige Snapshot vom Entry-Moment ---
        legText = dashEntryDir + " @Entry: Leg " + DoubleToString(dashEntryLeg, 1) +
                  "pt / min " + DoubleToString(dashEntryMinLeg, 1) +
                  "pt  " + (dashEntryLegOK ? "OK" : "FAIL");
        legColor = dashEntryLegOK ? clrLime : clrRed;

        legStatusText  = "IN POS (" + dashEntryDir + ")  ATR@E:" + DoubleToString(dashEntryMinLeg / InpLocalLegATRMultiplier, 1);
        legStatusColor = clrAqua;
    }
    else
    {
        // --- KEIN TRADE: Live-Tracking des laufenden Beins ---
        double minLegDash = InpLocalLegATRMultiplier * atrNowDash;
        double liveLeg;
        string dirLabel, phaseLabel;

        if(trend == -1)  // Pullback läuft → LONG Setup
        {
            dirLabel   = "LONG";
            phaseLabel = "Pullback";
            liveLeg    = (lastUptrendHigh > 0 && currentDowntrendLow > 0)
                         ? lastUptrendHigh - currentDowntrendLow : 0;
        }
        else  // trend == 1 → Retrace läuft → SHORT Setup
        {
            dirLabel   = "SHORT";
            phaseLabel = "Retrace";
            liveLeg    = (currentUptrendHigh > 0 && lastDowntrendLow > 0)
                         ? currentUptrendHigh - lastDowntrendLow : 0;
        }

        bool legOKDash = (liveLeg > 0 && liveLeg >= minLegDash);

        if(liveLeg == 0)
        { legText = dirLabel + " " + phaseLabel + ": warte auf HH/LL..."; legColor = clrGray; }
        else
        {
            legText = dirLabel + " " + phaseLabel + ": " + DoubleToString(liveLeg, 1) +
                      "pt  (min " + DoubleToString(minLegDash, 1) + "pt = " +
                      DoubleToString(InpLocalLegATRMultiplier, 1) + "xATR)  " +
                      (legOKDash ? "OK" : "FAIL");
            legColor = legOKDash ? clrLime : clrRed;
        }

        legStatusText  = (legOKDash ? "Leg:OK" : "Leg:FAIL") + "   ATR:" + DoubleToString(atrNowDash, 1);
        legStatusColor = legOKDash ? clrLime : clrRed;
    }

    ObjectSetString(0, dashboardName + "_LocalLeg", OBJPROP_TEXT, legText);
    ObjectSetInteger(0, dashboardName + "_LocalLeg", OBJPROP_COLOR, legColor);
    ObjectSetString(0, dashboardName + "_LegStatus", OBJPROP_TEXT, legStatusText);
    ObjectSetInteger(0, dashboardName + "_LegStatus", OBJPROP_COLOR, legStatusColor);

    // ADX Filter
    if(InpUseADXFilter)
    {
        bool adxOKDash = !InpADXTradeFilter || (adxMA >= InpADXMinimum && adxMA <= InpADXMaximum);
        color adxClrDash = adxOKDash ? clrLime : clrRed;
        ObjectSetString(0, dashboardName + "_ADX", OBJPROP_TEXT,
                       "ADX: " + DoubleToString(adxValue, 1) + " / MA: " + DoubleToString(adxMA, 1) +
                       (adxOKDash ? " ✓" : " ✗"));
        ObjectSetInteger(0, dashboardName + "_ADX", OBJPROP_COLOR, adxClrDash);
    }
    else
    {
        ObjectSetString(0, dashboardName + "_ADX", OBJPROP_TEXT, "ADX: OFF");
        ObjectSetInteger(0, dashboardName + "_ADX", OBJPROP_COLOR, clrGray);
    }

    ChartRedraw();
}

