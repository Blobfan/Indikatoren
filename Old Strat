void DrawSupertrendOnChart(string prefix, int atrHdl, ENUM_TIMEFRAMES tf,
                           int maxBarsLimit, color upClr, color dnClr,
                           int width, bool background)
{
    int bars = iBars(_Symbol, tf);
    int maxBars = MathMin(bars, maxBarsLimit);

    for(int i = ObjectsTotal(0) - 1; i >= 0; i--)
    {
        string objName = ObjectName(0, i);
        if(StringFind(objName, prefix) >= 0)
            ObjectDelete(0, objName);
    }

    double atr[], high_arr[], low_arr[], close_arr[];
    ArraySetAsSeries(atr, true);
    ArraySetAsSeries(high_arr, true);
    ArraySetAsSeries(low_arr, true);
    ArraySetAsSeries(close_arr, true);

    if(CopyBuffer(atrHdl, 0, 0, maxBars, atr) < maxBars) return;
    if(CopyHigh(_Symbol, tf, 0, maxBars, high_arr) < maxBars)  return;
    if(CopyLow(_Symbol, tf, 0, maxBars, low_arr) < maxBars)    return;
    if(CopyClose(_Symbol, tf, 0, maxBars, close_arr) < maxBars) return;

    double up_arr[], dn_arr[];
    int trend_arr[];
    ArrayResize(up_arr, maxBars);
    ArrayResize(dn_arr, maxBars);
    ArrayResize(trend_arr, maxBars);

    for(int i = maxBars - 1; i >= 0; i--)
    {
        double src = (high_arr[i] + low_arr[i]) / 2.0;
        double up  = src - InpSTmultiplier * atr[i];
        double dn  = src + InpSTmultiplier * atr[i];

        if(i < maxBars - 1)
        {
            if(close_arr[i + 1] > up_arr[i + 1]) up = MathMax(up, up_arr[i + 1]);
            if(close_arr[i + 1] < dn_arr[i + 1]) dn = MathMin(dn, dn_arr[i + 1]);

            int pt = trend_arr[i + 1];
            trend_arr[i] = pt;
            if(pt == -1 && close_arr[i] > dn_arr[i + 1])     trend_arr[i] = 1;
            else if(pt == 1 && close_arr[i] < up_arr[i + 1]) trend_arr[i] = -1;
        }
        else
            trend_arr[i] = 1;

        up_arr[i] = up;
        dn_arr[i] = dn;
    }

    for(int i = maxBars - 2; i >= 0; i--)
    {
        datetime t1 = iTime(_Symbol, tf, i + 1);
        datetime t2 = iTime(_Symbol, tf, i);

        double p1, p2;
        color  lineClr;

        bool trendChanged = (trend_arr[i] != trend_arr[i + 1]);

        if(trend_arr[i + 1] == 1)
        { p1 = up_arr[i + 1]; p2 = up_arr[i]; lineClr = upClr; }
        else
        { p1 = dn_arr[i + 1]; p2 = dn_arr[i]; lineClr = dnClr; }

        if(trendChanged && i >= maxBars - 2) continue;

        string objName = prefix + IntegerToString(i);
        if(ObjectCreate(0, objName, OBJ_TREND, 0, t1, p1, t2, p2))
        {
            ObjectSetInteger(0, objName, OBJPROP_COLOR, lineClr);
            ObjectSetInteger(0, objName, OBJPROP_WIDTH, width);
            ObjectSetInteger(0, objName, OBJPROP_RAY_RIGHT, false);
            ObjectSetInteger(0, objName, OBJPROP_BACK, background);
        }
    }

    ChartRedraw();
}

