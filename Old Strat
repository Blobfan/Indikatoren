int OnInit()
{
    DeleteAllObjects();

    g_emaFastHandle = iMA(_Symbol, PERIOD_CURRENT, InpEMAFast, 0, MODE_EMA, PRICE_CLOSE);
    g_emaSlowHandle = iMA(_Symbol, PERIOD_CURRENT, InpEMASlow, 0, MODE_EMA, PRICE_CLOSE);
    g_atrHandle     = iATR(_Symbol, PERIOD_CURRENT, InpSTperiod);

    if(g_emaFastHandle == INVALID_HANDLE || g_emaSlowHandle == INVALID_HANDLE || g_atrHandle == INVALID_HANDLE)
    {
        Print("Error creating indicator handles!");
        return INIT_FAILED;
    }

    if(InpUseHTF)
    {
        g_htfAtrHandle = iATR(_Symbol, InpHTFTimeframe, InpSTperiod);
        if(g_htfAtrHandle == INVALID_HANDLE)
        {
            Print("Error creating HTF ATR handle!");
            return INIT_FAILED;
        }
    }

    g_initialized = false;
    g_pos.Reset();
    g_stExtr.Reset();
    g_htfExtr.Reset();
    g_consol.Reset();

    ArrayResize(g_adxMaBuf, MathMax(InpADXSmoothing2, 1));
    ArrayInitialize(g_adxMaBuf, 0.0);
    ArrayResize(g_adxSeedBufDmPlus,  InpADXPeriod);
    ArrayResize(g_adxSeedBufDmMinus, InpADXPeriod);
    ArrayResize(g_adxSeedBufTr,      InpADXPeriod);
    ArrayInitialize(g_adxSeedBufDmPlus,  0.0);
    ArrayInitialize(g_adxSeedBufDmMinus, 0.0);
    ArrayInitialize(g_adxSeedBufTr,      0.0);
    g_adxSeedCount   = 0;
    g_adxRmaSeeded   = false;
    g_adxMaBufIdx    = 0;
    g_adxInitialized = false;
    g_adxRmaSmDmPlus = g_adxRmaSmDmMinus = g_adxRmaSmTr = g_adxRmaAdx = 0.0;
    g_adxPrevHigh = g_adxPrevLow = g_adxPrevClose = 0.0;
    g_adxLastBar  = 0;
    PreloadADX();

    InitCSVLog();
    if(InpShowDashboard) CreateDashboard();

    // FIX C: Version String korrigiert
    Print("DTFX Strategy EA v2.03 initialized");
    return INIT_SUCCEEDED;
}

void OnDeinit(const int reason)
{
    if(g_emaFastHandle != INVALID_HANDLE) IndicatorRelease(g_emaFastHandle);
    if(g_emaSlowHandle != INVALID_HANDLE) IndicatorRelease(g_emaSlowHandle);
    if(g_atrHandle     != INVALID_HANDLE) IndicatorRelease(g_atrHandle);
    if(g_htfAtrHandle  != INVALID_HANDLE) IndicatorRelease(g_htfAtrHandle);

    DeleteAllObjects();
    Print("DTFX Strategy EA deinitialized");
}

