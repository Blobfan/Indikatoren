void DeleteAllObjects()
{
    // FIX A: Nur noch DTFX_ Prefix – "SH_" und "SL_" waren zu generisch
    // und haben MT5-interne Chart-Objekte gelöscht → visuelle Fehler.
    for(int i = ObjectsTotal(0, 0, -1) - 1; i >= 0; i--)
    {
        string objName = ObjectName(0, i, 0, -1);
        if(StringFind(objName, "DTFX_") >= 0)
            ObjectDelete(0, objName);
    }
    ChartRedraw();
}
