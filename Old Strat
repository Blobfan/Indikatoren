bool IsHourInSession(int hour, int startHour, int endHour)
{
    if(startHour <= endHour)
        return (hour >= startHour && hour < endHour);
    else
        return (hour >= startHour || hour < endHour);
}

bool IsHourBlocked(int hour)
{
    if(InpBlockHour1 >= 0 && hour == InpBlockHour1) return true;
    if(InpBlockHour2 >= 0 && hour == InpBlockHour2) return true;
    if(InpBlockHour3 >= 0 && hour == InpBlockHour3) return true;
    if(InpBlockHour4 >= 0 && hour == InpBlockHour4) return true;
    if(InpBlockHour5 >= 0 && hour == InpBlockHour5) return true;
    return false;
}

bool IsInSession()
{
    if(!InpUseSessionFilter) return true;

    MqlDateTime gmtTime;
    TimeToStruct(TimeGMT(), gmtTime);
    int hour = gmtTime.hour;

    if(IsHourBlocked(hour)) return false;

    bool inLondon = InpEnableLondon && IsHourInSession(hour, InpLondonStartHour, InpLondonEndHour);
    bool inNY     = InpEnableNY     && IsHourInSession(hour, InpNYStartHour,     InpNYEndHour);
    bool inAsia   = InpEnableAsia   && IsHourInSession(hour, InpAsiaStartHour,   InpAsiaEndHour);

    return inLondon || inNY || inAsia;
}

