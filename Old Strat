void DrawSwingTriangle(string name, datetime time, double price, bool isHigh,
                       color triColor, double atrOffset, double sizeMultiplier,
                       long timeOffsetSec, int lineWidth)
{
    if(ObjectFind(0, name) >= 0) ObjectDelete(0, name);

    double adjusted  = isHigh ? (price + atrOffset) : (price - atrOffset);
    double triSize   = atrOffset * sizeMultiplier;
    datetime tOff    = (datetime)timeOffsetSec;

    datetime t1, t2, t3;
    double   p1, p2, p3;

    if(isHigh)
    {
        t1 = time - tOff; p1 = adjusted + triSize;
        t2 = time + tOff; p2 = adjusted + triSize;
        t3 = time;         p3 = adjusted;
    }
    else
    {
        t1 = time - tOff; p1 = adjusted - triSize;
        t2 = time + tOff; p2 = adjusted - triSize;
        t3 = time;         p3 = adjusted;
    }

    if(ObjectCreate(0, name, OBJ_TRIANGLE, 0, t1, p1, t2, p2, t3, p3))
    {
        ObjectSetInteger(0, name, OBJPROP_COLOR, triColor);
        ObjectSetInteger(0, name, OBJPROP_FILL, true);
        ObjectSetInteger(0, name, OBJPROP_BACK, false);
        ObjectSetInteger(0, name, OBJPROP_WIDTH, lineWidth);
    }
}

void DrawCTFSwingLabel(string name, int shift, double price, bool isHigh)
{
    datetime time = iTime(_Symbol, PERIOD_CURRENT, shift);
    double atrBuf[];
    ArraySetAsSeries(atrBuf, true);
    double offset;

    if(CopyBuffer(g_atrHandle, 0, shift, 1, atrBuf) > 0)
        offset = atrBuf[0] * 0.5;
    else
        offset = (iHigh(_Symbol, PERIOD_CURRENT, shift) - iLow(_Symbol, PERIOD_CURRENT, shift)) * 2;

    color col = isHigh ? clrRed : clrLime;
    DrawSwingTriangle(name, time, price, isHigh, col, offset, 0.3,
                      PeriodSeconds(PERIOD_CURRENT), 2);
}

void DrawHTFSwingLabel(string name, int htfShift, double price, bool isHigh)
{
    datetime htfBarTime    = iTime(_Symbol, InpHTFTimeframe, htfShift);
    datetime htfBarEndTime = htfBarTime + PeriodSeconds(InpHTFTimeframe);
    int ctfStart = iBarShift(_Symbol, PERIOD_CURRENT, htfBarEndTime);
    int ctfEnd   = iBarShift(_Symbol, PERIOD_CURRENT, htfBarTime);

    int extremeBar      = ctfEnd;
    double extremeValue = isHigh ? 0 : DBL_MAX;

    for(int i = ctfStart; i <= ctfEnd; i++)
    {
        if(isHigh)
        {
            double h = iHigh(_Symbol, PERIOD_CURRENT, i);
            if(h > extremeValue) { extremeValue = h; extremeBar = i; }
        }
        else
        {
            double l = iLow(_Symbol, PERIOD_CURRENT, i);
            if(l < extremeValue) { extremeValue = l; extremeBar = i; }
        }
    }

    datetime time = iTime(_Symbol, PERIOD_CURRENT, extremeBar);
    double atrBuf[];
    ArraySetAsSeries(atrBuf, true);
    double offset;

    if(CopyBuffer(g_atrHandle, 0, extremeBar, 1, atrBuf) > 0)
        offset = atrBuf[0] * 0.8;
    else
        offset = (iHigh(_Symbol, PERIOD_CURRENT, extremeBar) - iLow(_Symbol, PERIOD_CURRENT, extremeBar)) * 3;

    long htfTimeOff = (long)(PeriodSeconds(InpHTFTimeframe) * 0.5);
    DrawSwingTriangle(name, time, price, isHigh, InpHTFSwingColor, offset, 0.5, htfTimeOff, 3);
}

void DrawConsolidationBox()
{
    if(!InpShowConsolidation)
    {
        for(int i = ObjectsTotal(0) - 1; i >= 0; i--)
        {
            string objName = ObjectName(0, i);
            if(StringFind(objName, "DTFX_Consol_") >= 0)
                ObjectDelete(0, objName);
        }
        return;
    }

    if(!g_consol.active && g_consol.boxName != "")
    {
        if(ObjectFind(0, g_consol.boxName) >= 0)
        {
            ObjectSetInteger(0, g_consol.boxName, OBJPROP_TIME, 1, iTime(_Symbol, PERIOD_CURRENT, 0));
            if(InpDebugLog) Print("Consolidation Box finalized: ", g_consol.boxName);
        }
        g_consol.boxName      = "";
        g_consol.startTime    = 0;
        g_consol.rangeHigh    = 0;
        g_consol.rangeLow     = 0;
        g_consol.bufferedHigh = 0;
        g_consol.bufferedLow  = 0;
        return;
    }

    if(g_consol.active && g_consol.startTime > 0 && g_consol.rangeHigh > 0 && g_consol.rangeLow > 0)
    {
        if(g_consol.boxName == "")
            g_consol.boxName = "DTFX_Consol_" + IntegerToString(g_consol.startTime);

        if(ObjectFind(0, g_consol.boxName) >= 0)
            ObjectDelete(0, g_consol.boxName);

        datetime curTime = iTime(_Symbol, PERIOD_CURRENT, 0);
        if(ObjectCreate(0, g_consol.boxName, OBJ_RECTANGLE, 0,
                        g_consol.startTime, g_consol.bufferedHigh, curTime, g_consol.bufferedLow))
        {
            int transparency = (int)((InpConsolTransparency / 100.0) * 255);
            ObjectSetInteger(0, g_consol.boxName, OBJPROP_COLOR, InpConsolColor);
            ObjectSetInteger(0, g_consol.boxName, OBJPROP_STYLE, STYLE_SOLID);
            ObjectSetInteger(0, g_consol.boxName, OBJPROP_WIDTH, InpConsolBorderWidth);
            ObjectSetInteger(0, g_consol.boxName, OBJPROP_FILL, true);
            ObjectSetInteger(0, g_consol.boxName, OBJPROP_BACK, true);

            color bgColor = InpConsolColor;
            long r = (bgColor & 0xFF);
            long g = ((bgColor >> 8) & 0xFF);
            long b = ((bgColor >> 16) & 0xFF);
            long alphaColor = (transparency << 24) | (b << 16) | (g << 8) | r;
            ObjectSetInteger(0, g_consol.boxName, OBJPROP_BGCOLOR, alphaColor);
        }
    }
}

