void OnTick()
{
    CheckTradeClose();

    static datetime lastBarTime = 0;
    datetime currentBarTime = iTime(_Symbol, PERIOD_CURRENT, 0);
    if(currentBarTime == lastBarTime)
    {
        if(InpShowDashboard) UpdateDashboard();
        return;
    }
    lastBarTime = currentBarTime;

    if(!AreIndicatorsReady()) return;

    if(!g_initialized && Bars(_Symbol, PERIOD_CURRENT) >= MathMin(InpWarmupBars, 34))
        InitializeSwingStructure();
    else if(g_initialized)
    {
        CalculateSupertrend();
        UpdateSwingStructure();
        ProcessSupertrendFlip();

        if(InpShowSupertrendLines)
            DrawSupertrendOnChart(PFX_ST, g_atrHandle, PERIOD_CURRENT, 500,
                                 clrLime, clrRed, InpSupertrendWidth, false);
        DrawEMALines();
        UpdateADX();
        CheckTradeSignals();
        ManageOpenTrades();

        if(InpShowDashboard) UpdateDashboard();
    }

    if(InpUseHTF && g_htfInitialized)
    {
        UpdateHTFSwingStructure();
        if(InpShowHTFSupertrendLines)
            DrawSupertrendOnChart(PFX_HTF_ST, g_htfAtrHandle, InpHTFTimeframe, 200,
                                 InpHTFSupertrendUpColor, InpHTFSupertrendDownColor,
                                 InpHTFSupertrendWidth, true);
    }
}

bool AreIndicatorsReady()
{
    return BarsCalculated(g_emaFastHandle) >= 1
        && BarsCalculated(g_emaSlowHandle) >= 1
        && BarsCalculated(g_atrHandle)     >= 1;
}

