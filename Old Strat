void CheckTradeSignals()
{
    if(!InpEnableTrade) return;
    if(g_stTrend == g_stPrevTrend) return;

    bool buySignal  = (g_stTrend == 1  && g_stPrevTrend == -1);
    bool sellSignal = (g_stTrend == -1 && g_stPrevTrend == 1);

    double high1  = iHigh(_Symbol, PERIOD_CURRENT, 1);
    double low1   = iLow(_Symbol, PERIOD_CURRENT, 1);
    double close1 = iClose(_Symbol, PERIOD_CURRENT, 1);

    bool allowNew  = !g_consol.active;
    bool inSession = IsInSession();
    bool adxOK     = !InpUseADXFilter || !InpADXTradeFilter || (g_adxMA >= InpADXMinimum && g_adxMA <= InpADXMaximum);

    if(buySignal)
    {
        bool noHigherHigh = (g_validSH == 0 || close1 <= g_validSH);
        bool htfAligned   = IsHTFAligned(BOS_UP);
        bool emaOK        = (InpEMAFilterMode == EMA_FILTER_DISABLED) || g_emaCaptureLong;

        if(InpDebugLog)
            Print("[LONG] up=", g_isUptrend, " ema=", emaOK,
                  " (cap=", g_emaCaptureLong, " below=", g_emaBelowSlow, ")",
                  " noHH=", noHigherHigh, " (close=", close1, " SH=", g_validSH, ")",
                  " allow=", allowNew, " htf=", htfAligned,
                  " sess=", inSession, " adx=", adxOK, " consol=", g_consol.active);

        if(g_isUptrend && emaOK && noHigherHigh && InpAllowLongTrades
           && allowNew && htfAligned && inSession && adxOK)
        {
            // FIX B: Gegenposition nur schließen wenn Verlust im akzeptablen Bereich
            if(PositionSelect(_Symbol) && PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_SELL)
            {
                double posProfit = PositionGetDouble(POSITION_PROFIT);
                if(posProfit >= InpMaxCounterLoss)
                {
                    g_trade.PositionClose(_Symbol);
                    if(InpDebugLog) Print("[CLOSE SHORT] Profit=", posProfit, " >= Limit=", InpMaxCounterLoss);
                }
                else
                {
                    Print("[SKIP CLOSE SHORT] Profit=", posProfit, " < Limit=", InpMaxCounterLoss,
                          " – Datenschutz aktiv, kein neuer Trade");
                    return;
                }
            }

            double sl = (g_validSL > 0) ? g_validSL : low1 * 0.98;
            double tp = (g_validSH > 0) ? g_validSH : high1 * 1.02;

            if(InpUseFixedRRR) tp = close1 + MathAbs(close1 - sl) * InpRiskRewardRatio;
            if(InpStopLossPoints > 0)   sl = low1  - InpStopLossPoints * _Point;
            if(InpTakeProfitPoints > 0) tp = high1 + InpTakeProfitPoints * _Point;

            g_pos.entryPrice    = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
            g_pos.targetTP      = tp;
            g_pos.stopLoss      = sl;
            g_pos.initialRisk   = MathAbs(g_pos.entryPrice - sl);
            g_pos.beTriggered   = false;
            g_pos.tpTriggered   = false;
            g_pos.isLong        = true;
            g_pos.partialClosed = false;
            g_pos.active        = true;

            double orderTP = InpUseTrailingSL ? 0 : tp;
            g_trade.Buy(InpLotSize, _Symbol, 0, sl, orderTP, "DTFX LONG");

            Print("LONG: Entry=", g_pos.entryPrice, " SL=", sl, " TP=", tp);
            if(g_trade.ResultRetcode() == TRADE_RETCODE_DONE)
            {
                LogTrade("BUY", g_pos.entryPrice, sl, tp, true, g_emaCaptureLong, noHigherHigh, allowNew, htfAligned);
                g_emaCaptureLong = false;
                g_emaBelowSlow   = false;
            }
        }
        else if(!htfAligned && InpDebugLog)
            Print("LONG BLOCKED: HTF (", BosToString(g_htfBosDir), ")");
    }

    if(sellSignal)
    {
        bool noLowerLow = (g_validSL == 0 || close1 >= g_validSL);
        bool htfAligned = IsHTFAligned(BOS_DOWN);
        bool emaOK      = (InpEMAFilterMode == EMA_FILTER_DISABLED) || g_emaCaptureShort;

        if(InpDebugLog)
            Print("[SHORT] dn=", g_isDowntrend, " ema=", emaOK,
                  " (cap=", g_emaCaptureShort, " above=", g_emaAboveSlow, ")",
                  " noLL=", noLowerLow, " allow=", allowNew,
                  " htf=", htfAligned, " sess=", inSession, " adx=", adxOK);

        if(g_isDowntrend && emaOK && noLowerLow && InpAllowShortTrades
           && allowNew && htfAligned && inSession && adxOK)
        {
            // FIX B: Gegenposition nur schließen wenn Verlust im akzeptablen Bereich
            if(PositionSelect(_Symbol) && PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY)
            {
                double posProfit = PositionGetDouble(POSITION_PROFIT);
                if(posProfit >= InpMaxCounterLoss)
                {
                    g_trade.PositionClose(_Symbol);
                    if(InpDebugLog) Print("[CLOSE LONG] Profit=", posProfit, " >= Limit=", InpMaxCounterLoss);
                }
                else
                {
                    Print("[SKIP CLOSE LONG] Profit=", posProfit, " < Limit=", InpMaxCounterLoss,
                          " – Datenschutz aktiv, kein neuer Trade");
                    return;
                }
            }

            double sl = (g_validSH > 0) ? g_validSH : high1 * 1.02;
            double tp = (g_validSL > 0) ? g_validSL : low1 * 0.98;

            if(InpUseFixedRRR) tp = close1 - MathAbs(close1 - sl) * InpRiskRewardRatio;
            if(InpStopLossPoints > 0)   sl = high1 + InpStopLossPoints * _Point;
            if(InpTakeProfitPoints > 0) tp = low1  - InpTakeProfitPoints * _Point;

            g_pos.entryPrice    = SymbolInfoDouble(_Symbol, SYMBOL_BID);
            g_pos.targetTP      = tp;
            g_pos.stopLoss      = sl;
            g_pos.initialRisk   = MathAbs(g_pos.entryPrice - sl);
            g_pos.beTriggered   = false;
            g_pos.tpTriggered   = false;
            g_pos.isLong        = false;
            g_pos.partialClosed = false;
            g_pos.active        = true;

            double orderTP = InpUseTrailingSL ? 0 : tp;
            g_trade.Sell(InpLotSize, _Symbol, 0, sl, orderTP, "DTFX SHORT");

            Print("SHORT: Entry=", g_pos.entryPrice, " SL=", sl, " TP=", tp);
            if(g_trade.ResultRetcode() == TRADE_RETCODE_DONE)
            {
                LogTrade("SELL", g_pos.entryPrice, sl, tp, true, g_emaCaptureShort, noLowerLow, allowNew, htfAligned);
                g_emaCaptureShort = false;
                g_emaAboveSlow    = false;
            }
        }
        else if(!htfAligned && InpDebugLog)
            Print("SHORT BLOCKED: HTF (", BosToString(g_htfBosDir), ")");
    }
}

