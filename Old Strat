double WilderRMA(double prevRMA, double value, int length)
{
    return prevRMA + (value - prevRMA) / length;
}

void PreloadADX()
{
    int totalBars = iBars(_Symbol, InpADXTimeframe);
    if(totalBars < 2) return;
    int warmup   = (InpADXPeriod + InpADXSmoothing) * 3;
    int lookback = MathMin(totalBars - 1, warmup + 2);

    g_adxPrevHigh  = iHigh (_Symbol, InpADXTimeframe, lookback);
    g_adxPrevLow   = iLow  (_Symbol, InpADXTimeframe, lookback);
    g_adxPrevClose = iClose(_Symbol, InpADXTimeframe, lookback);
    g_adxInitialized = true;

    for(int i = lookback - 1; i >= 1; i--)
    {
        double h = iHigh (_Symbol, InpADXTimeframe, i);
        double l = iLow  (_Symbol, InpADXTimeframe, i);
        double c = iClose(_Symbol, InpADXTimeframe, i);
        double upMove   = h - g_adxPrevHigh;
        double downMove = g_adxPrevLow - l;
        double plusDM   = (upMove > downMove && upMove > 0)   ? upMove   : 0.0;
        double minusDM  = (downMove > upMove && downMove > 0) ? downMove : 0.0;
        double tr = MathMax(h - l, MathMax(MathAbs(h - g_adxPrevClose), MathAbs(l - g_adxPrevClose)));
        g_adxPrevHigh = h; g_adxPrevLow = l; g_adxPrevClose = c;

        if(!g_adxRmaSeeded)
        {
            int idx = g_adxSeedCount % InpADXPeriod;
            g_adxSeedBufDmPlus[idx]  = plusDM;
            g_adxSeedBufDmMinus[idx] = minusDM;
            g_adxSeedBufTr[idx]      = tr;
            g_adxSeedCount++;
            if(g_adxSeedCount >= InpADXPeriod)
            {
                double sumDmP = 0, sumDmM = 0, sumTr = 0;
                for(int j = 0; j < InpADXPeriod; j++)
                { sumDmP += g_adxSeedBufDmPlus[j]; sumDmM += g_adxSeedBufDmMinus[j]; sumTr += g_adxSeedBufTr[j]; }
                g_adxRmaSmDmPlus  = sumDmP / InpADXPeriod;
                g_adxRmaSmDmMinus = sumDmM / InpADXPeriod;
                g_adxRmaSmTr      = sumTr  / InpADXPeriod;
                double diP_s    = (g_adxRmaSmTr > 0) ? 100.0 * g_adxRmaSmDmPlus  / g_adxRmaSmTr : 0.0;
                double diM_s    = (g_adxRmaSmTr > 0) ? 100.0 * g_adxRmaSmDmMinus / g_adxRmaSmTr : 0.0;
                double diS_s    = diP_s + diM_s;
                g_adxRmaAdx       = (diS_s == 0) ? 0.0 : 100.0 * MathAbs(diP_s - diM_s) / diS_s;
                g_adxRmaSeeded    = true;
            }
        }
        else
        {
            g_adxRmaSmDmPlus  = WilderRMA(g_adxRmaSmDmPlus,  plusDM,  InpADXPeriod);
            g_adxRmaSmDmMinus = WilderRMA(g_adxRmaSmDmMinus, minusDM, InpADXPeriod);
            g_adxRmaSmTr      = WilderRMA(g_adxRmaSmTr,      tr,      InpADXPeriod);
            if(g_adxRmaSmTr > 0)
            {
                double diPlus  = 100.0 * g_adxRmaSmDmPlus  / g_adxRmaSmTr;
                double diMinus = 100.0 * g_adxRmaSmDmMinus / g_adxRmaSmTr;
                double diSum   = diPlus + diMinus;
                double dx      = (diSum == 0) ? 0.0 : 100.0 * MathAbs(diPlus - diMinus) / diSum;
                g_adxRmaAdx      = WilderRMA(g_adxRmaAdx, dx, InpADXSmoothing);
            }
        }
    }
    if(g_adxRmaSeeded)
    {
        g_adxValue = g_adxRmaAdx;
        int maLen = MathMax(InpADXSmoothing2, 1);
        ArrayResize(g_adxMaBuf, maLen);
        ArrayInitialize(g_adxMaBuf, g_adxValue);
        g_adxMaBufIdx = maLen;
        g_adxMA = g_adxValue;
    }
    g_adxLastBar = iTime(_Symbol, InpADXTimeframe, 1);
}

void UpdateADX()
{
    datetime barTime = iTime(_Symbol, InpADXTimeframe, 1);
    if(barTime == g_adxLastBar) return;
    g_adxLastBar = barTime;

    double high1  = iHigh (_Symbol, InpADXTimeframe, 1);
    double low1   = iLow  (_Symbol, InpADXTimeframe, 1);
    double close1 = iClose(_Symbol, InpADXTimeframe, 1);

    if(!g_adxInitialized)
    {
        g_adxPrevHigh  = high1;
        g_adxPrevLow   = low1;
        g_adxPrevClose = close1;
        g_adxInitialized = true;
        return;
    }

    double upMove   = high1      - g_adxPrevHigh;
    double downMove = g_adxPrevLow - low1;
    double plusDM   = (upMove > downMove && upMove > 0)   ? upMove   : 0.0;
    double minusDM  = (downMove > upMove && downMove > 0) ? downMove : 0.0;

    double tr = MathMax(high1 - low1,
                MathMax(MathAbs(high1 - g_adxPrevClose),
                        MathAbs(low1  - g_adxPrevClose)));

    g_adxPrevHigh  = high1;
    g_adxPrevLow   = low1;
    g_adxPrevClose = close1;

    if(!g_adxRmaSeeded)
    {
        int idx = g_adxSeedCount % InpADXPeriod;
        g_adxSeedBufDmPlus[idx]  = plusDM;
        g_adxSeedBufDmMinus[idx] = minusDM;
        g_adxSeedBufTr[idx]      = tr;
        g_adxSeedCount++;

        if(g_adxSeedCount >= InpADXPeriod)
        {
            double sumDmP = 0, sumDmM = 0, sumTr = 0;
            for(int i = 0; i < InpADXPeriod; i++)
            {
                sumDmP += g_adxSeedBufDmPlus[i];
                sumDmM += g_adxSeedBufDmMinus[i];
                sumTr  += g_adxSeedBufTr[i];
            }
            g_adxRmaSmDmPlus  = sumDmP / InpADXPeriod;
            g_adxRmaSmDmMinus = sumDmM / InpADXPeriod;
            g_adxRmaSmTr      = sumTr  / InpADXPeriod;

            double diP_s = (g_adxRmaSmTr > 0) ? 100.0 * g_adxRmaSmDmPlus  / g_adxRmaSmTr : 0.0;
            double diM_s = (g_adxRmaSmTr > 0) ? 100.0 * g_adxRmaSmDmMinus / g_adxRmaSmTr : 0.0;
            double diS_s = diP_s + diM_s;
            g_adxRmaAdx = (diS_s == 0) ? 0.0 : 100.0 * MathAbs(diP_s - diM_s) / diS_s;

            g_adxRmaSeeded = true;
        }
        g_adxValue = 0.0;
        g_adxMA    = 0.0;
        return;
    }

    g_adxRmaSmDmPlus  = WilderRMA(g_adxRmaSmDmPlus,  plusDM,  InpADXPeriod);
    g_adxRmaSmDmMinus = WilderRMA(g_adxRmaSmDmMinus, minusDM, InpADXPeriod);
    g_adxRmaSmTr      = WilderRMA(g_adxRmaSmTr,      tr,      InpADXPeriod);

    if(g_adxRmaSmTr == 0) return;

    double diPlus  = 100.0 * g_adxRmaSmDmPlus  / g_adxRmaSmTr;
    double diMinus = 100.0 * g_adxRmaSmDmMinus / g_adxRmaSmTr;
    double diSum   = diPlus + diMinus;
    double dx      = (diSum == 0) ? 0.0 : 100.0 * MathAbs(diPlus - diMinus) / diSum;

    g_adxRmaAdx = WilderRMA(g_adxRmaAdx, dx, InpADXSmoothing);
    g_adxValue  = g_adxRmaAdx;

    int maLen = MathMax(InpADXSmoothing2, 1);
    g_adxMaBuf[g_adxMaBufIdx % maLen] = g_adxValue;
    g_adxMaBufIdx++;
    double sum = 0;
    int    cnt = MathMin(g_adxMaBufIdx, maLen);
    for(int i = 0; i < cnt; i++) sum += g_adxMaBuf[i];
    g_adxMA = (cnt > 0) ? sum / cnt : 0.0;
}

//+==================================================================+
//| SECTION 8: SUPERTREND CORE                                       |
//+==================================================================+

void CalculateSupertrend()
{
    double atr[];
    ArraySetAsSeries(atr, true);
    if(CopyBuffer(g_atrHandle, 0, 0, 3, atr) < 3) return;

    double high1  = iHigh(_Symbol, PERIOD_CURRENT, 1);
    double low1   = iLow(_Symbol, PERIOD_CURRENT, 1);
    double close1 = iClose(_Symbol, PERIOD_CURRENT, 1);
    double close2 = iClose(_Symbol, PERIOD_CURRENT, 2);

    double src = (high1 + low1) / 2.0;
    double up  = src - InpSTmultiplier * atr[1];
    double dn  = src + InpSTmultiplier * atr[1];

    double prevUp = (g_stPrevUp > 0) ? g_stPrevUp : up;
    double prevDn = (g_stPrevDn > 0) ? g_stPrevDn : dn;

    if(close2 > prevUp) up = MathMax(up, prevUp);
    if(close2 < prevDn) dn = MathMin(dn, prevDn);

    g_stPrevUp = up;
    g_stPrevDn = dn;

    g_stPrevTrend = g_stTrend;
    if(g_stTrend == -1 && close1 > prevDn)     g_stTrend = 1;
    else if(g_stTrend == 1 && close1 < prevUp) g_stTrend = -1;

    if(InpEMAFilterMode != EMA_FILTER_DISABLED)
    {
        double emaVal[];
        ArraySetAsSeries(emaVal, true);
        if(CopyBuffer(g_emaSlowHandle, 0, 0, 3, emaVal) >= 3)
        {
            double ema1 = emaVal[1];
            double ema2 = emaVal[2];

            if(InpEMAFilterMode == EMA_FILTER_UNDER_EMA)
            {
                if(g_arm == ARM_PULLBACK_DOWN && low1 < ema1 && !g_emaBelowSlow)
                {
                    g_emaBelowSlow = true;
                    if(InpDebugLog) Print("[EMA] belowSlow=TRUE (low=", low1, " ema=", ema1, ")");
                }
                if(g_arm == ARM_PULLBACK_UP && high1 > ema1 && !g_emaAboveSlow)
                {
                    g_emaAboveSlow = true;
                    if(InpDebugLog) Print("[EMA] aboveSlow=TRUE (high=", high1, " ema=", ema1, ")");
                }
            }
            else
            {
                if(g_arm == ARM_PULLBACK_DOWN && close2 > ema2 && close1 < ema1 && !g_emaBelowSlow)
                {
                    g_emaBelowSlow = true;
                    if(InpDebugLog) Print("[EMA] CROSSOVER belowSlow=TRUE");
                }
                if(g_arm == ARM_PULLBACK_UP && close2 < ema2 && close1 > ema1 && !g_emaAboveSlow)
                {
                    g_emaAboveSlow = true;
                    if(InpDebugLog) Print("[EMA] CROSSOVER aboveSlow=TRUE");
                }
            }
        }
    }

    if(g_stPrevTrend == 1 && (high1 > g_stExtr.currentHigh || g_stExtr.currentHigh == 0))
    {
        g_stExtr.currentHigh     = high1;
        g_stExtr.currentHighTime = iTime(_Symbol, PERIOD_CURRENT, 1);
    }
    if(g_stPrevTrend == -1 && (low1 < g_stExtr.currentLow || g_stExtr.currentLow == 0))
    {
        g_stExtr.currentLow     = low1;
        g_stExtr.currentLowTime = iTime(_Symbol, PERIOD_CURRENT, 1);
    }

    if(g_stTrend != g_stPrevTrend && g_stPrevTrend != 0)
    {
        if(g_stTrend == -1)
        {
            g_stExtr.lastHigh     = g_stExtr.currentHigh;
            g_stExtr.lastHighTime = g_stExtr.currentHighTime;
            g_stExtr.currentLow     = 0;
            g_stExtr.currentLowTime = 0;
            if(InpDebugLog) Print("ST→DOWN: HIGH=", g_stExtr.lastHigh, " @", TimeToString(g_stExtr.lastHighTime));
        }
        else
        {
            g_stExtr.lastLow      = g_stExtr.currentLow;
            g_stExtr.lastLowTime  = g_stExtr.currentLowTime;
            g_stExtr.currentHigh     = 0;
            g_stExtr.currentHighTime = 0;
            if(InpDebugLog) Print("ST→UP: LOW=", g_stExtr.lastLow, " @", TimeToString(g_stExtr.lastLowTime));
        }
    }
}

