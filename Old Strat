string BosToString(ENUM_BOS_DIR dir)
{
    if(dir == BOS_UP)   return "UP";
    if(dir == BOS_DOWN) return "DOWN";
    return "NONE";
}

string ArmToString(ENUM_ARM_STATE arm)
{
    if(arm == ARM_MOVE_UP)       return "MOVE_UP";
    if(arm == ARM_MOVE_DOWN)     return "MOVE_DOWN";
    if(arm == ARM_PULLBACK_UP)   return "PULLBACK_UP";
    if(arm == ARM_PULLBACK_DOWN) return "PULLBACK_DOWN";
    return "UNDECIDED";
}

bool CheckSameBarEMA(bool checkBelow)
{
    if(InpEMAFilterMode == EMA_FILTER_DISABLED) return false;

    double ema[];
    ArraySetAsSeries(ema, true);
    if(CopyBuffer(g_emaSlowHandle, 0, 0, 3, ema) < 3) return false;

    if(InpEMAFilterMode == EMA_FILTER_UNDER_EMA)
    {
        if(checkBelow) return iLow(_Symbol, PERIOD_CURRENT, 1) < ema[1];
        else           return iHigh(_Symbol, PERIOD_CURRENT, 1) > ema[1];
    }
    else
    {
        double c1 = iClose(_Symbol, PERIOD_CURRENT, 1);
        double c2 = iClose(_Symbol, PERIOD_CURRENT, 2);
        if(checkBelow) return (c2 > ema[2] && c1 < ema[1]);
        else           return (c2 < ema[2] && c1 > ema[1]);
    }
}

void InitCSVLog()
{
    string ts = TimeToString(TimeCurrent(), TIME_DATE);
    StringReplace(ts, ".", "-");
    g_logFileName = _Symbol + "_OLD_P" + IntegerToString(PERIOD_CURRENT) + "_" + ts + ".csv";
    FolderCreate("DTFX_Logs", FILE_COMMON);
    int fh = FileOpen("DTFX_Logs\\" + g_logFileName, FILE_WRITE | FILE_TXT | FILE_ANSI | FILE_COMMON);
    if(fh != INVALID_HANDLE)
    {
        FileWriteString(fh, "DateTime,Strategy,TradeType,Session,EntryPrice,StopLoss,TakeProfit,ValidSH,ValidSL,ATR,AllowDir,EMAAllow,SwingIntact,RangeWide,HTFAlign,ADX\r\n");
        FileClose(fh);
        Print("CSV Log: ", g_logFileName);
    }
    else
        Print("CSV Log ERROR: ", GetLastError());
}

