//+==================================================================+

void InitializeHTFSwingStructure()
{
    if(!InpUseHTF) return;

    int htfBars = iBars(_Symbol, InpHTFTimeframe);
    if(htfBars < 34) return;

    int highestBar = iHighest(_Symbol, InpHTFTimeframe, MODE_HIGH, 34, 1);
    int lowestBar  = iLowest(_Symbol, InpHTFTimeframe, MODE_LOW, 34, 1);

    g_htfValidSH = iHigh(_Symbol, InpHTFTimeframe, highestBar);
    g_htfValidSL = iLow(_Symbol, InpHTFTimeframe, lowestBar);

    double curHigh  = iHigh(_Symbol, InpHTFTimeframe, 1);
    double prevHigh = iHigh(_Symbol, InpHTFTimeframe, 2);
    g_htfTrend     = (curHigh > prevHigh) ? 1 : -1;
    g_htfPrevTrend = g_htfTrend;
    g_htfBosDir    = (g_htfTrend == 1) ? BOS_UP : BOS_DOWN;

    if(InpShowSwingLabels)
    {
        DrawHTFSwingLabel("HTF_SH_INIT", highestBar, g_htfValidSH, true);
        DrawHTFSwingLabel("HTF_SL_INIT", lowestBar, g_htfValidSL, false);
    }

    g_htfInitialized = true;
    g_lastHTFBarTime = iTime(_Symbol, InpHTFTimeframe, 0);
    Print("HTF init: SH=", g_htfValidSH, " SL=", g_htfValidSL, " TF=", EnumToString(InpHTFTimeframe));
}

void UpdateHTFSwingStructure()
{
    if(!InpUseHTF || !g_htfInitialized) return;

    datetime curHTFBarTime = iTime(_Symbol, InpHTFTimeframe, 0);
    if(curHTFBarTime == g_lastHTFBarTime) return;
    g_lastHTFBarTime = curHTFBarTime;

    CalculateHTFSupertrend();

    bool htfBuy  = (g_htfTrend == 1  && g_htfPrevTrend == -1);
    bool htfSell = (g_htfTrend == -1 && g_htfPrevTrend == 1);

    if(htfSell && g_htfExtr.lastHigh > 0)
    {
        g_htfValidSH = g_htfExtr.lastHigh;
        int barIdx = iBarShift(_Symbol, InpHTFTimeframe, g_htfExtr.lastHighTime);
        if(InpShowSwingLabels)
            DrawHTFSwingLabel("HTF_SH_" + IntegerToString(TimeCurrent()), barIdx, g_htfExtr.lastHigh, true);
        if(InpDebugLog) Print("HTF H @Bar ", barIdx, " P=", g_htfExtr.lastHigh);
    }

    if(htfBuy && g_htfExtr.lastLow > 0)
    {
        g_htfValidSL = g_htfExtr.lastLow;
        int barIdx = iBarShift(_Symbol, InpHTFTimeframe, g_htfExtr.lastLowTime);
        if(InpShowSwingLabels)
            DrawHTFSwingLabel("HTF_SL_" + IntegerToString(TimeCurrent()), barIdx, g_htfExtr.lastLow, false);
        if(InpDebugLog) Print("HTF L @Bar ", barIdx, " P=", g_htfExtr.lastLow);
    }

    double c1 = iClose(_Symbol, InpHTFTimeframe, 1);
    double o1 = iOpen(_Symbol, InpHTFTimeframe, 1);
    double bodyHi = MathMax(c1, o1);
    double bodyLo = MathMin(c1, o1);

    if(g_htfValidSH > 0 && bodyHi > g_htfValidSH)
    {
        g_htfBosDir = BOS_UP;
        if(InpDebugLog) Print("HTF BOS UP: ", bodyHi, " > ", g_htfValidSH);
    }
    if(g_htfValidSL > 0 && bodyLo < g_htfValidSL)
    {
        g_htfBosDir = BOS_DOWN;
        if(InpDebugLog) Print("HTF BOS DOWN: ", bodyLo, " < ", g_htfValidSL);
    }
}

bool IsHTFAligned(ENUM_BOS_DIR direction)
{
    if(!InpUseHTF || !InpRequireHTFAlignment) return true;
    return g_htfBosDir == direction;
}

