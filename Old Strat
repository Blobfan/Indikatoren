void ManageOpenTrades()
{
    if(!PositionSelect(_Symbol))
    {
        g_pos.Reset();
        return;
    }
    if(!g_pos.active) return;

    double currentSL    = PositionGetDouble(POSITION_SL);
    double currentTP    = PositionGetDouble(POSITION_TP);
    double currentBid   = SymbolInfoDouble(_Symbol, SYMBOL_BID);
    double currentAsk   = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
    double currentPrice = g_pos.isLong ? currentBid : currentAsk;
    double newSL        = currentSL;
    bool   modifyNeeded = false;

    if(InpUseBreakeven && !g_pos.beTriggered && g_pos.initialRisk > 0)
    {
        if(g_pos.isLong && currentPrice >= g_pos.entryPrice + InpBreakevenR * g_pos.initialRisk)
        {
            newSL              = MathMax(newSL, g_pos.entryPrice);
            g_pos.beTriggered  = true;
            modifyNeeded       = true;
            Print("[BE] Long: SL → Entry ", g_pos.entryPrice);
        }
        else if(!g_pos.isLong && currentPrice <= g_pos.entryPrice - InpBreakevenR * g_pos.initialRisk)
        {
            newSL              = (newSL > 0) ? MathMin(newSL, g_pos.entryPrice) : g_pos.entryPrice;
            g_pos.beTriggered  = true;
            modifyNeeded       = true;
            Print("[BE] Short: SL → Entry ", g_pos.entryPrice);
        }
    }

    if(InpUseTrailingSL)
    {
        if(!g_pos.tpTriggered && g_pos.targetTP > 0)
        {
            bool tpHit = g_pos.isLong ? (currentPrice >= g_pos.targetTP)
                                      : (currentPrice <= g_pos.targetTP);
            if(tpHit)
            {
                g_pos.tpTriggered = true;
                Print("[Scaling] TP1 ", g_pos.targetTP, " erreicht → Runner aktiv");

                if(InpUsePartialClose && !g_pos.partialClosed)
                {
                    double posVol   = PositionGetDouble(POSITION_VOLUME);
                    double closeVol = NormalizeDouble(posVol * InpPartialClosePercent / 100.0, 2);
                    double minVol   = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
                    if(closeVol >= minVol && (posVol - closeVol) >= minVol)
                    {
                        if(g_trade.PositionClosePartial(_Symbol, closeVol))
                        {
                            g_pos.partialClosed = true;
                            Print("[Partial] ", closeVol, " Lots @ TP1");
                        }
                    }
                }

                if(g_pos.isLong)
                {
                    double slTarget = 0;
                    if(InpScalingMethod == SCALING_SUPERTREND && g_stPrevUp > 0)
                        slTarget = g_stPrevUp;
                    else if(InpScalingMethod == SCALING_VALID_SWING && g_validSL > g_pos.entryPrice)
                        slTarget = g_validSL;

                    if(slTarget > g_pos.entryPrice)
                    {
                        newSL = MathMax(newSL, slTarget);
                        Print("[Scaling] Long TP1: SL → ", (InpScalingMethod == SCALING_SUPERTREND ? "ST-Up " : "validSL "), slTarget);
                    }
                    else
                    {
                        newSL = MathMax(newSL, g_pos.entryPrice);
                        Print("[Scaling] Long TP1: kein Level über Entry → BE ", g_pos.entryPrice);
                    }
                }
                else
                {
                    double slTarget = 0;
                    if(InpScalingMethod == SCALING_SUPERTREND && g_stPrevDn > 0)
                        slTarget = g_stPrevDn;
                    else if(InpScalingMethod == SCALING_VALID_SWING && g_validSH > 0 && g_validSH < g_pos.entryPrice)
                        slTarget = g_validSH;

                    if(slTarget > 0 && slTarget < g_pos.entryPrice)
                    {
                        newSL = (newSL > 0) ? MathMin(newSL, slTarget) : slTarget;
                        Print("[Scaling] Short TP1: SL → ", (InpScalingMethod == SCALING_SUPERTREND ? "ST-Dn " : "validSH "), slTarget);
                    }
                    else
                    {
                        newSL = (newSL > 0) ? MathMin(newSL, g_pos.entryPrice) : g_pos.entryPrice;
                        Print("[Scaling] Short TP1: kein Level unter Entry → BE ", g_pos.entryPrice);
                    }
                }
                modifyNeeded = true;
            }
        }

        if(g_pos.tpTriggered)
        {
            if(g_pos.isLong)
            {
                double trailLevel = (InpScalingMethod == SCALING_SUPERTREND) ? g_stPrevUp : g_validSL;
                if(trailLevel > 0 && trailLevel > newSL)
                {
                    Print("[Trailing] Long SL: ", newSL, " → ", trailLevel);
                    newSL        = trailLevel;
                    modifyNeeded = true;
                }
            }
            else
            {
                double trailLevel = (InpScalingMethod == SCALING_SUPERTREND) ? g_stPrevDn : g_validSH;
                if(trailLevel > 0 && newSL > 0 && trailLevel < newSL)
                {
                    Print("[Trailing] Short SL: ", newSL, " → ", trailLevel);
                    newSL        = trailLevel;
                    modifyNeeded = true;
                }
            }
        }
    }

    if(modifyNeeded && MathAbs(newSL - currentSL) > _Point)
    {
        g_pos.stopLoss = newSL;
        double newTP = (InpUseTrailingSL && g_pos.tpTriggered) ? 0 : currentTP;
        if(g_trade.PositionModify(_Symbol, NormalizeDouble(newSL, _Digits), NormalizeDouble(newTP, _Digits)))
            Print("[Modify] SL → ", newSL, (g_pos.beTriggered ? " [BE]" : ""), (g_pos.tpTriggered ? " [Trail]" : ""));
        else
            Print("[Modify] Fehler: ", GetLastError());
    }
}

