//+==================================================================+
//| SECTION 8b: STARTUP WARMUP                                       |
//+==================================================================+

void RunWarmup()
{
    if(InpWarmupBars <= 0) return;
    WarmupCTFSupertrend();
    if(InpUseHTF && g_htfAtrHandle != INVALID_HANDLE)
        WarmupHTFSupertrend();
}

void WarmupCTFSupertrend()
{
    int count = MathMin(InpWarmupBars + 3, Bars(_Symbol, PERIOD_CURRENT));
    if(count < 4) return;

    double atr[], hi[], lo[], cl[], op[];
    datetime tm[];
    ArraySetAsSeries(atr, true); ArraySetAsSeries(hi, true);
    ArraySetAsSeries(lo,  true); ArraySetAsSeries(cl, true);
    ArraySetAsSeries(op,  true); ArraySetAsSeries(tm, true);

    if(CopyBuffer(g_atrHandle, 0, 0, count, atr) < count) return;
    if(CopyHigh  (_Symbol, PERIOD_CURRENT, 0, count, hi ) < count) return;
    if(CopyLow   (_Symbol, PERIOD_CURRENT, 0, count, lo ) < count) return;
    if(CopyClose (_Symbol, PERIOD_CURRENT, 0, count, cl ) < count) return;
    if(CopyOpen  (_Symbol, PERIOD_CURRENT, 0, count, op ) < count) return;
    if(CopyTime  (_Symbol, PERIOD_CURRENT, 0, count, tm ) < count) return;

    double prevUp = 0, prevDn = 0;
    int    wTrend = 1;
    g_stExtr.Reset();

    int      wArm        = ARM_UNDECIDED;
    int      wPrevArm    = ARM_UNDECIDED;
    bool     wIsUptrend  = true;
    bool     wIsDowntrend= false;
    bool     wBosInArm   = false;
    double   wValidSH    = 0,  wValidSL    = 0;
    datetime wValidSHTime= 0,  wValidSLTime= 0;

    bool     wConsolActive = false;
    datetime wConsolStart  = 0;
    double   wConsolHigh   = 0, wConsolLow = 0;

    for(int i = count - 1; i >= 2; i--)
    {
        double h1     = hi[i];
        double l1     = lo[i];
        double c1     = cl[i];
        double o1     = op[i];
        double c_prev = (i + 1 < count) ? cl[i + 1] : c1;

        double src = (h1 + l1) / 2.0;
        double up  = src - InpSTmultiplier * atr[i];
        double dn  = src + InpSTmultiplier * atr[i];

        if(prevUp > 0)
        {
            if(c_prev > prevUp) up = MathMax(up, prevUp);
            if(c_prev < prevDn) dn = MathMin(dn, prevDn);
        }

        int prevTrend = wTrend;
        if(wTrend == -1 && c1 > prevDn)     wTrend = 1;
        else if(wTrend == 1 && c1 < prevUp) wTrend = -1;

        if(prevTrend == 1  && (h1 > g_stExtr.currentHigh || g_stExtr.currentHigh == 0))
            { g_stExtr.currentHigh = h1; g_stExtr.currentHighTime = tm[i]; }
        if(prevTrend == -1 && (l1 < g_stExtr.currentLow  || g_stExtr.currentLow  == 0))
            { g_stExtr.currentLow  = l1; g_stExtr.currentLowTime  = tm[i]; }

        if(wIsUptrend && wArm == ARM_PULLBACK_DOWN && h1 > g_stExtr.currentHigh)
            { g_stExtr.currentHigh = h1; g_stExtr.currentHighTime = tm[i]; }
        if(wIsDowntrend && wArm == ARM_PULLBACK_UP && l1 < g_stExtr.currentLow)
            { g_stExtr.currentLow  = l1; g_stExtr.currentLowTime  = tm[i]; }

        double bodyHi = MathMax(c1, o1);
        double bodyLo = MathMin(c1, o1);
        if(wValidSH > 0 && bodyHi > wValidSH && !wBosInArm)
            { wBosInArm = true; wIsUptrend = true;  wIsDowntrend = false; }
        if(wValidSL > 0 && bodyLo < wValidSL && !wBosInArm)
            { wBosInArm = true; wIsUptrend = false; wIsDowntrend = true;  }

        if(wConsolActive)
        {
            double _cRange   = wConsolHigh - wConsolLow;
            double _cHalfBuf = _cRange * (InpConsolBufferPct / 100.0) / 2.0;
            double buffH = wConsolHigh + _cHalfBuf;
            double buffL = wConsolLow  - _cHalfBuf;
            if(wBosInArm || bodyHi > buffH || bodyLo < buffL)
            {
                if(InpShowConsolidation)
                {
                    string cName = "DTFX_Consol_" + IntegerToString((int)wConsolStart);
                    if(ObjectFind(0, cName) >= 0) ObjectDelete(0, cName);
                    if(ObjectCreate(0, cName, OBJ_RECTANGLE, 0, wConsolStart, buffH, tm[i], buffL))
                    {
                        ObjectSetInteger(0, cName, OBJPROP_COLOR,  InpConsolColor);
                        ObjectSetInteger(0, cName, OBJPROP_STYLE,  STYLE_SOLID);
                        ObjectSetInteger(0, cName, OBJPROP_WIDTH,  InpConsolBorderWidth);
                        ObjectSetInteger(0, cName, OBJPROP_FILL,   true);
                        ObjectSetInteger(0, cName, OBJPROP_BACK,   true);
                        int transparency = (int)((InpConsolTransparency / 100.0) * 255);
                        color bgColor = InpConsolColor;
                        long r = (bgColor & 0xFF);
                        long g_c = ((bgColor >> 8) & 0xFF);
                        long b = ((bgColor >> 16) & 0xFF);
                        long alphaColor = (transparency << 24) | (b << 16) | (g_c << 8) | r;
                        ObjectSetInteger(0, cName, OBJPROP_BGCOLOR, alphaColor);
                    }
                }
                wConsolActive = false;
            }
        }

        if(wTrend != prevTrend)
        {
            bool wMoveEndedWithoutBOS = false;
            if((ENUM_ARM_STATE)wPrevArm == ARM_MOVE_UP   && wTrend == -1 && wIsUptrend)
                wMoveEndedWithoutBOS = !wBosInArm;
            if((ENUM_ARM_STATE)wPrevArm == ARM_MOVE_DOWN  && wTrend == 1  && wIsDowntrend)
                wMoveEndedWithoutBOS = !wBosInArm;

            if(wTrend == -1)
            {
                g_stExtr.lastHigh     = g_stExtr.currentHigh;
                g_stExtr.lastHighTime = g_stExtr.currentHighTime;
                g_stExtr.currentLow     = 0;
                g_stExtr.currentLowTime = 0;
                if(g_stExtr.lastHigh > 0)
                {
                    wValidSH     = g_stExtr.lastHigh;
                    wValidSHTime = g_stExtr.lastHighTime;
                    if(InpShowSwingLabels)
                    {
                        int barIdx = iBarShift(_Symbol, PERIOD_CURRENT, g_stExtr.lastHighTime);
                        DrawCTFSwingLabel("SH_" + IntegerToString((int)g_stExtr.lastHighTime), barIdx, g_stExtr.lastHigh, true);
                    }
                }
                wArm = (wIsUptrend) ? ARM_PULLBACK_DOWN : ARM_MOVE_DOWN;
            }
            else
            {
                g_stExtr.lastLow     = g_stExtr.currentLow;
                g_stExtr.lastLowTime = g_stExtr.currentLowTime;
                g_stExtr.currentHigh     = 0;
                g_stExtr.currentHighTime = 0;
                if(g_stExtr.lastLow > 0)
                {
                    wValidSL     = g_stExtr.lastLow;
                    wValidSLTime = g_stExtr.lastLowTime;
                    if(InpShowSwingLabels)
                    {
                        int barIdx = iBarShift(_Symbol, PERIOD_CURRENT, g_stExtr.lastLowTime);
                        DrawCTFSwingLabel("SL_" + IntegerToString((int)g_stExtr.lastLowTime), barIdx, g_stExtr.lastLow, false);
                    }
                }
                wArm = (wIsDowntrend) ? ARM_PULLBACK_UP : ARM_MOVE_UP;
            }
            wBosInArm = false;

            if(wMoveEndedWithoutBOS && !wConsolActive && InpShowConsolidation
               && wValidSH > 0 && wValidSL > 0)
            {
                wConsolActive = true;
                wConsolStart  = (datetime)MathMin((long)wValidSHTime, (long)wValidSLTime);
                wConsolHigh   = wValidSH;
                wConsolLow    = wValidSL;
            }

            wPrevArm = wArm;
        }

        prevUp = up;
        prevDn = dn;
    }

    g_stTrend     = wTrend;
    g_stPrevTrend = wTrend;
    g_stPrevUp    = prevUp;
    g_stPrevDn    = prevDn;

    g_isUptrend   = wIsUptrend;
    g_isDowntrend = wIsDowntrend;
    g_bosInArm    = wBosInArm;
    g_arm         = (ENUM_ARM_STATE)wArm;
    g_prevArm     = (ENUM_ARM_STATE)wPrevArm;
    g_validSH     = wValidSH;
    g_validSHBar  = (wValidSHTime > 0) ? iBarShift(_Symbol, PERIOD_CURRENT, wValidSHTime) : -1;
    g_validSL     = wValidSL;
    g_validSLBar  = (wValidSLTime > 0) ? iBarShift(_Symbol, PERIOD_CURRENT, wValidSLTime) : -1;

    if(wConsolActive)
    {
        g_consol.active    = true;
        g_consol.startTime = wConsolStart;
        g_consol.rangeHigh = wConsolHigh;
        g_consol.rangeLow  = wConsolLow;
        double _cRange     = wConsolHigh - wConsolLow;
        double _cHalfBuf   = _cRange * (InpConsolBufferPct / 100.0) / 2.0;
        g_consol.bufferedHigh = wConsolHigh + _cHalfBuf;
        g_consol.bufferedLow  = wConsolLow  - _cHalfBuf;
    }

    Print("CTF Warmup (", InpWarmupBars, " Bars): trend=", wTrend,
          " isUp=", wIsUptrend, " arm=", ArmToString((ENUM_ARM_STATE)wArm),
          " lastHigh=", g_stExtr.lastHigh, " lastLow=", g_stExtr.lastLow);
}

void WarmupHTFSupertrend()
{
    int count = MathMin(InpWarmupBars + 3, iBars(_Symbol, InpHTFTimeframe));
    if(count < 4) return;

    double atr[], hi[], lo[], cl[], op[];
    datetime tm[];
    ArraySetAsSeries(atr, true); ArraySetAsSeries(hi, true);
    ArraySetAsSeries(lo,  true); ArraySetAsSeries(cl, true);
    ArraySetAsSeries(op,  true); ArraySetAsSeries(tm, true);

    if(CopyBuffer(g_htfAtrHandle, 0, 0, count, atr) < count) return;
    if(CopyHigh  (_Symbol, InpHTFTimeframe, 0, count, hi ) < count) return;
    if(CopyLow   (_Symbol, InpHTFTimeframe, 0, count, lo ) < count) return;
    if(CopyClose (_Symbol, InpHTFTimeframe, 0, count, cl ) < count) return;
    if(CopyOpen  (_Symbol, InpHTFTimeframe, 0, count, op ) < count) return;
    if(CopyTime  (_Symbol, InpHTFTimeframe, 0, count, tm ) < count) return;

    double prevUp = 0, prevDn = 0;
    int    wTrend = 1;
    g_htfExtr.Reset();

    double htfSH = 0, htfSL = DBL_MAX;
    int    initWindow = MathMin(34, count);
    for(int j = count - 1; j >= count - initWindow; j--)
    {
        if(hi[j] > htfSH) htfSH = hi[j];
        if(lo[j] < htfSL) htfSL = lo[j];
    }
    if(htfSL == DBL_MAX) htfSL = 0;

    ENUM_BOS_DIR htfBos = BOS_NONE;

    for(int i = count - 1; i >= 2; i--)
    {
        double h1     = hi[i];
        double l1     = lo[i];
        double c1     = cl[i];
        double o1     = op[i];
        double c_prev = (i + 1 < count) ? cl[i + 1] : c1;

        double src = (h1 + l1) / 2.0;
        double up  = src - InpSTmultiplier * atr[i];
        double dn  = src + InpSTmultiplier * atr[i];
        if(prevUp > 0)
        {
            if(c_prev > prevUp) up = MathMax(up, prevUp);
            if(c_prev < prevDn) dn = MathMin(dn, prevDn);
        }

        int prevTrend = wTrend;
        if(wTrend == -1 && c1 > prevDn)     wTrend = 1;
        else if(wTrend == 1 && c1 < prevUp) wTrend = -1;

        if(wTrend == 1  && (h1 > g_htfExtr.currentHigh || g_htfExtr.currentHigh == 0))
            { g_htfExtr.currentHigh = h1; g_htfExtr.currentHighTime = tm[i]; }
        if(wTrend == -1 && (l1 < g_htfExtr.currentLow  || g_htfExtr.currentLow  == 0))
            { g_htfExtr.currentLow  = l1; g_htfExtr.currentLowTime  = tm[i]; }

        if(wTrend != prevTrend)
        {
            if(wTrend == -1)
            {
                g_htfExtr.lastHigh     = g_htfExtr.currentHigh;
                g_htfExtr.lastHighTime = g_htfExtr.currentHighTime;
                g_htfExtr.currentLow     = 0;
                g_htfExtr.currentLowTime = 0;
                if(g_htfExtr.lastHigh > 0)
                {
                    htfSH = g_htfExtr.lastHigh;
                    if(InpShowSwingLabels)
                    {
                        int htfBarIdx = iBarShift(_Symbol, InpHTFTimeframe, g_htfExtr.lastHighTime);
                        DrawHTFSwingLabel("HTF_SH_" + IntegerToString((int)tm[i]), htfBarIdx, g_htfExtr.lastHigh, true);
                    }
                }
            }
            else
            {
                g_htfExtr.lastLow     = g_htfExtr.currentLow;
                g_htfExtr.lastLowTime = g_htfExtr.currentLowTime;
                g_htfExtr.currentHigh     = 0;
                g_htfExtr.currentHighTime = 0;
                if(g_htfExtr.lastLow > 0)
                {
                    htfSL = g_htfExtr.lastLow;
                    if(InpShowSwingLabels)
                    {
                        int htfBarIdx = iBarShift(_Symbol, InpHTFTimeframe, g_htfExtr.lastLowTime);
                        DrawHTFSwingLabel("HTF_SL_" + IntegerToString((int)tm[i]), htfBarIdx, g_htfExtr.lastLow, false);
                    }
                }
            }
        }

        double bodyHi = MathMax(c1, o1);
        double bodyLo = MathMin(c1, o1);

        if(htfSH > 0 && bodyHi > htfSH)
        {
            htfBos = BOS_UP;
            htfSH  = h1;
        }
        if(htfSL > 0 && bodyLo < htfSL)
        {
            htfBos = BOS_DOWN;
            htfSL  = l1;
        }

        prevUp = up;
        prevDn = dn;
    }

    g_htfTrend       = wTrend;
    g_htfPrevTrend   = wTrend;
    g_htfPrevUp      = prevUp;
    g_htfPrevDn      = prevDn;
    g_htfValidSH     = htfSH;
    g_htfValidSL     = (htfSL == DBL_MAX) ? 0 : htfSL;
    g_htfBosDir      = htfBos;
    g_htfInitialized = true;
    g_lastHTFBarTime = iTime(_Symbol, InpHTFTimeframe, 0);

    Print("HTF Warmup (", InpWarmupBars, " Bars): trend=", wTrend,
          " BOS=", BosToString(htfBos), " SH=", htfSH, " SL=", g_htfValidSL);
}

//+==================================================================+
//| SECTION 9: SWING STRUCTURE                                       |
//+==================================================================+

void InitializeSwingStructure()
{
    int bars = Bars(_Symbol, PERIOD_CURRENT);
    if(bars < 34) return;

    RunWarmup();

    if(InpWarmupBars <= 0)
    {
        g_isUptrend   = (iHigh(_Symbol, PERIOD_CURRENT, 1) > iHigh(_Symbol, PERIOD_CURRENT, 2));
        g_isDowntrend = !g_isUptrend;
        g_bosInArm    = false;
        g_arm         = g_isUptrend ? ARM_MOVE_UP : ARM_MOVE_DOWN;
        int lookback  = 34;
        int highestBar = iHighest(_Symbol, PERIOD_CURRENT, MODE_HIGH, lookback, 1);
        g_validSH     = iHigh(_Symbol, PERIOD_CURRENT, highestBar);
        g_validSHBar  = highestBar;
        int lowestBar  = iLowest(_Symbol, PERIOD_CURRENT, MODE_LOW, lookback, 1);
        g_validSL     = iLow(_Symbol, PERIOD_CURRENT, lowestBar);
        g_validSLBar  = lowestBar;
    }

    g_initialized = true;
    g_bosDir      = (g_stTrend == 1) ? BOS_UP : BOS_DOWN;

    CalculateSupertrend();
    g_bosDir = (g_stTrend == 1) ? BOS_UP : BOS_DOWN;

    if(!g_htfInitialized)
        InitializeHTFSwingStructure();

    if(InpShowSupertrendLines)
        DrawSupertrendOnChart(PFX_ST, g_atrHandle, PERIOD_CURRENT, 500,
                             clrLime, clrRed, InpSupertrendWidth, false);
    DrawEMALines();

    if(g_consol.active)
        DrawConsolidationBox();

    if(g_stTrend != g_stPrevTrend)
        ProcessSupertrendFlip();

    Print("Swing init v2.03: SH=", g_validSH, " SL=", g_validSL,
          " trend=", (g_isUptrend ? "UP" : "DOWN"),
          " bosDir=", BosToString(g_bosDir),
          " warmup=", (InpWarmupBars > 0 ? "ON" : "OFF"));
}

void UpdateSwingStructure()
{
    double high1  = iHigh(_Symbol, PERIOD_CURRENT, 1);
    double low1   = iLow(_Symbol, PERIOD_CURRENT, 1);
    double close1 = iClose(_Symbol, PERIOD_CURRENT, 1);
    double open1  = iOpen(_Symbol, PERIOD_CURRENT, 1);
    double bodyHi = MathMax(close1, open1);
    double bodyLo = MathMin(close1, open1);

    if(g_isUptrend && g_arm == ARM_PULLBACK_DOWN && high1 > g_stExtr.currentHigh)
    {
        g_stExtr.currentHigh     = high1;
        g_stExtr.currentHighTime = iTime(_Symbol, PERIOD_CURRENT, 1);
    }
    if(g_isDowntrend && g_arm == ARM_PULLBACK_UP && low1 < g_stExtr.currentLow)
    {
        g_stExtr.currentLow     = low1;
        g_stExtr.currentLowTime = iTime(_Symbol, PERIOD_CURRENT, 1);
    }

    if(g_validSH > 0 && bodyHi > g_validSH && !g_bosInArm)
    {
        g_bosInArm    = true;
        g_bosDir      = BOS_UP;
        g_isUptrend   = true;
        g_isDowntrend = false;
    }
    if(g_validSL > 0 && bodyLo < g_validSL && !g_bosInArm)
    {
        g_bosInArm    = true;
        g_bosDir      = BOS_DOWN;
        g_isUptrend   = false;
        g_isDowntrend = true;
    }
}

//+==================================================================+
//| SECTION 10: SUPERTREND ARM MANAGEMENT                            |
//+==================================================================+

void ProcessSupertrendFlip()
{
    bool buySignal  = (g_stTrend == 1  && g_stPrevTrend == -1);
    bool sellSignal = (g_stTrend == -1 && g_stPrevTrend == 1);

    bool moveArmEndedWithoutBOS = false;
    if(g_prevArm == ARM_MOVE_UP && sellSignal && g_isUptrend)
        moveArmEndedWithoutBOS = !g_bosInArm;
    if(g_prevArm == ARM_MOVE_DOWN && buySignal && g_isDowntrend)
        moveArmEndedWithoutBOS = !g_bosInArm;

    double close1 = iClose(_Symbol, PERIOD_CURRENT, 1);
    double open1  = iOpen(_Symbol, PERIOD_CURRENT, 1);
    double bodyHi = MathMax(close1, open1);
    double bodyLo = MathMin(close1, open1);

    bool bosUp   = (g_validSH > 0 && bodyHi > g_validSH && !g_bosInArm);
    bool bosDown = (g_validSL > 0 && bodyLo < g_validSL && !g_bosInArm);

    bool pullbackBOSDuringConsol = false;
    if(g_consol.active && (bosUp || bosDown))
    {
        if((sellSignal && g_isUptrend) || (buySignal && g_isDowntrend))
            pullbackBOSDuringConsol = true;
    }

    if(g_consol.active)
    {
        bool breakout = (bodyHi > g_consol.bufferedHigh || bodyLo < g_consol.bufferedLow);
        if(bosUp || bosDown || pullbackBOSDuringConsol || breakout)
        {
            g_consol.active = false;
            if(InpDebugLog) Print("Consolidation ENDED");
        }
    }

    if(sellSignal)
    {
        g_emaCaptureShort = g_emaAboveSlow;

        if(g_isUptrend)
        {
            g_arm = ARM_PULLBACK_DOWN;
            g_emaBelowSlow = false;

            if(g_consol.active)
            {
                g_consol.active = false;
                if(InpDebugLog) Print("[Consol] Reset durch PULLBACK_DOWN");
            }

            if(CheckSameBarEMA(true))
            {
                g_emaBelowSlow = true;
                if(InpDebugLog) Print("[EMA] Same-Bar-Fix SELL: belowEMA=TRUE");
            }
        }
        else
            g_arm = ARM_MOVE_DOWN;

        g_emaAboveSlow = false;
        g_bosInArm     = false;

        if(g_stExtr.lastHigh > 0)
        {
            g_validSH    = g_stExtr.lastHigh;
            g_validSHBar = iBarShift(_Symbol, PERIOD_CURRENT, g_stExtr.lastHighTime);
            if(InpShowSwingLabels)
                DrawCTFSwingLabel("SH_" + IntegerToString(TimeCurrent()), g_validSHBar, g_stExtr.lastHigh, true);
            if(InpDebugLog) Print("H @Bar ", g_validSHBar, " P=", g_stExtr.lastHigh,
                                  " EMA-Short=", g_emaCaptureShort, " arm=", ArmToString(g_arm));
        }
        else
            if(InpDebugLog) Print("[SELL] kein lastHigh - arm=", ArmToString(g_arm));
    }

    if(buySignal)
    {
        g_emaCaptureLong = g_emaBelowSlow;

        if(g_isDowntrend)
        {
            g_arm = ARM_PULLBACK_UP;
            g_emaAboveSlow = false;

            if(g_consol.active)
            {
                g_consol.active = false;
                if(InpDebugLog) Print("[Consol] Reset durch PULLBACK_UP");
            }

            if(CheckSameBarEMA(false))
            {
                g_emaAboveSlow = true;
                if(InpDebugLog) Print("[EMA] Same-Bar-Fix BUY: aboveEMA=TRUE");
            }
        }
        else
            g_arm = ARM_MOVE_UP;

        g_emaBelowSlow = false;
        g_bosInArm     = false;

        if(g_stExtr.lastLow > 0)
        {
            g_validSL    = g_stExtr.lastLow;
            g_validSLBar = iBarShift(_Symbol, PERIOD_CURRENT, g_stExtr.lastLowTime);
            if(InpShowSwingLabels)
                DrawCTFSwingLabel("SL_" + IntegerToString(TimeCurrent()), g_validSLBar, g_stExtr.lastLow, false);
            if(InpDebugLog) Print("L @Bar ", g_validSLBar, " P=", g_stExtr.lastLow,
                                  " EMA-Long=", g_emaCaptureLong, " arm=", ArmToString(g_arm));
        }
        else
            if(InpDebugLog) Print("[BUY] kein lastLow - arm=", ArmToString(g_arm));
    }

    if(moveArmEndedWithoutBOS && !g_consol.active && InpShowConsolidation)
    {
        g_consol.active    = true;
        g_consol.startTime = (datetime)MathMin(iTime(_Symbol, PERIOD_CURRENT, g_validSHBar),
                                               iTime(_Symbol, PERIOD_CURRENT, g_validSLBar));
        g_consol.rangeHigh  = g_validSH;
        g_consol.rangeLow   = g_validSL;
        double _consolRange   = g_consol.rangeHigh - g_consol.rangeLow;
        double _consolHalfBuf = _consolRange * (InpConsolBufferPct / 100.0) / 2.0;
        g_consol.bufferedHigh = g_consol.rangeHigh + _consolHalfBuf;
        g_consol.bufferedLow  = g_consol.rangeLow  - _consolHalfBuf;
        if(InpDebugLog) Print("Consolidation START: H=", g_consol.rangeHigh, " L=", g_consol.rangeLow);
    }

    g_prevArm = g_arm;
    DrawConsolidationBox();
}

