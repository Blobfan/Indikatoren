void CheckTradeClose()
{
    static ulong    trackedTickets[];
    static datetime trackedTimes[];

    ulong    openTickets[];
    datetime openTimes[];
    int posTotal = PositionsTotal();
    for(int i = 0; i < posTotal; i++)
    {
        ulong tk = PositionGetTicket(i);
        if(!PositionSelectByTicket(tk)) continue;
        if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
        int n = ArraySize(openTickets);
        ArrayResize(openTickets, n + 1);
        ArrayResize(openTimes,   n + 1);
        openTickets[n] = tk;
        openTimes[n]   = (datetime)PositionGetInteger(POSITION_TIME);
    }

    for(int i = 0; i < ArraySize(openTickets); i++)
    {
        bool found = false;
        for(int j = 0; j < ArraySize(trackedTickets); j++)
            if(trackedTickets[j] == openTickets[i]) { found = true; break; }
        if(!found)
        {
            int n = ArraySize(trackedTickets);
            ArrayResize(trackedTickets, n + 1);
            ArrayResize(trackedTimes,   n + 1);
            trackedTickets[n] = openTickets[i];
            trackedTimes[n]   = openTimes[i];
        }
    }

    for(int j = ArraySize(trackedTickets) - 1; j >= 0; j--)
    {
        bool stillOpen = false;
        for(int i = 0; i < ArraySize(openTickets); i++)
            if(openTickets[i] == trackedTickets[j]) { stillOpen = true; break; }

        if(!stillOpen)
        {
            ulong    closedTk = trackedTickets[j];
            datetime entryTm  = trackedTimes[j];

            HistorySelectByPosition(closedTk);

            string result     = "UNKNOWN";
            double closePrice = 0;
            double entryPrice = 0;
            double profit     = 0;

            for(int i = HistoryDealsTotal() - 1; i >= 0; i--)
            {
                ulong dk = HistoryDealGetTicket(i);
                if(HistoryDealGetString(dk, DEAL_SYMBOL) != _Symbol)              continue;
                if(HistoryDealGetInteger(dk, DEAL_ENTRY) != DEAL_ENTRY_OUT)       continue;
                if((ulong)HistoryDealGetInteger(dk, DEAL_POSITION_ID) != closedTk) continue;

                closePrice = HistoryDealGetDouble(dk, DEAL_PRICE);
                profit     = HistoryDealGetDouble(dk, DEAL_PROFIT);
                ENUM_DEAL_REASON reason = (ENUM_DEAL_REASON)HistoryDealGetInteger(dk, DEAL_REASON);

                for(int k = 0; k < HistoryDealsTotal(); k++)
                {
                    ulong t2 = HistoryDealGetTicket(k);
                    if((ulong)HistoryDealGetInteger(t2, DEAL_POSITION_ID) == closedTk &&
                       HistoryDealGetInteger(t2, DEAL_ENTRY) == DEAL_ENTRY_IN)
                    {
                        entryPrice = HistoryDealGetDouble(t2, DEAL_PRICE);
                        break;
                    }
                }

                if(reason == DEAL_REASON_TP)      result = "TP";
                else if(reason == DEAL_REASON_SL) result = "SL";
                else result = (profit > 0) ? "TP" : "SL";
                break;
            }

            LogTradeResult(result, entryTm, entryPrice, closePrice, profit);
            ArrayRemove(trackedTickets, j, 1);
            ArrayRemove(trackedTimes,   j, 1);
        }
    }
}

